<UserControl x:Class="HnVue.UI.Views.MergeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:HnVue.UI.Converters"
             xmlns:designTime="clr-namespace:HnVue.UI.DesignTime"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1400"
             d:DataContext="{d:DesignInstance designTime:DesignTimeMergeViewModel, IsDesignTimeCreatable=True}">
    <!--
        @MX:NOTE MergeView — "Sync Study" dialog. PPT 슬라이드 12-13.
                 UISPEC-006 v2.0 기준 구현.
                 Layout: Patient A lane | Patient B lane | Preview (larger).
                 각 lane: Only WorkList 체크, 검색, patient list, study list.
                 Preview panel: Image A/B 비교 + thumbnail strip.
                 PatientRecord.Name is DICOM PN format (family^given^...).
    -->
    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <!-- PPT Slide 12: 목록 스타일 통일 (Worklist/Studylist와 동일) -->
        <Style x:Key="MergeHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Surface.Panel}"/>
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Text.Secondary}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}"/>
        </Style>
        <Style x:Key="MergeRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Surface.Page}"/>
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Component.DataGrid.GridLine}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Surface.Card}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HnVue.Component.DataGrid.SelectionBg}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Brand.PrimaryLight}"/>
                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource HnVue.Semantic.Surface.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                BorderThickness="0,0,0,1"
                Padding="16,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- PPT: 파란 title bar icon -->
                    <TextBlock Text="&#xE8FD;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="16"
                               Foreground="{DynamicResource HnVue.Semantic.Brand.Accent}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Sync Study"
                               Style="{StaticResource HnVue.SectionHeader}"
                               VerticalAlignment="Center"/>
                    <!-- PPT Slide 3: Section badge "병합 화면" -->
                    <Border Background="{DynamicResource HnVue.Component.SectionBadge.Bg}"
                            CornerRadius="3"
                            Padding="8,2"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="병합 화면"
                                   Style="{StaticResource HnVue.SectionBadgeText}"/>
                    </Border>
                </StackPanel>
                <!-- Close button (우측) -->
                <Button HorizontalAlignment="Right"
                        Content="&#xE711;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource HnVue.OutlineButton}"
                        Width="36" Height="36"
                        Padding="0"
                        ToolTip="Close"/>
            </Grid>
        </Border>

        <!-- ═══ Three-column main area: Patient A | Patient B | Preview ═══ -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <!-- PPT Slide 12: A/B lane 동일 비율 -->
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="3*"/>
                <!-- PPT notes: 우측 preview 더 크게 -->
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════ Patient A Lane ═══════════════════ -->
            <Border Grid.Column="0"
                    Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                    BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                    BorderThickness="0,0,1,0"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="120"/>
                    </Grid.RowDefinitions>

                    <!-- Lane header with checkbox -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Patient A"
                                       Style="{StaticResource HnVue.SectionHeader}"
                                       Foreground="{DynamicResource HnVue.Semantic.Brand.Accent}"/>
                        </StackPanel>
                        <!-- PPT UISPEC-006: Only WorkList checkbox -->
                        <CheckBox Grid.Column="1"
                                  Content="Only WorkList"
                                  Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                  FontSize="11"
                                  FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding OnlyWorkListA}"/>
                    </Grid>

                    <!-- Search A row -->
                    <Border Grid.Row="1"
                            Height="32" CornerRadius="4"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1"
                            Margin="0,0,0,8"
                            Padding="8,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchQueryA, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                                     BorderThickness="0" FontSize="12"
                                     VerticalAlignment="Center"
                                     FontFamily="{DynamicResource HnVue.Core.FontFamily}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SearchACommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="2"
                                    Content="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding SearchACommand}"
                                    Style="{StaticResource HnVue.OutlineButton}"
                                    Width="28" Height="26" Padding="0" FontSize="12"/>
                        </Grid>
                    </Border>

                    <!-- Patient A list -->
                    <TextBlock Grid.Row="2"
                               Text="환자 목록"
                               Style="{StaticResource HnVue.UppercaseLabel}"
                               Margin="0,0,0,4"/>
                    <ListBox Grid.Row="3"
                             ItemsSource="{Binding PatientsA}"
                             SelectedItem="{Binding SelectedPatientA}"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="{DynamicResource HnVue.Core.FontFamily}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <!-- PPT: 44px touch target (WCAG 2.5.5) -->
                                <Setter Property="Height" Value="44"/>
                                <Setter Property="Padding" Value="8,0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Border.Default}"/>
                                <Style.Triggers>
                                    <!-- PPT: 선택 row 파란 highlight -->
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource HnVue.Component.DataGrid.SelectionBg}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Brand.PrimaryLight}"/>
                                        <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Surface.Card}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <!-- PatientRecord.Name is DICOM PN (family^given) -->
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                                        <TextBlock Text="{Binding PatientId}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                                   FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Study list for Patient A (PPT Slide 12: 스터디 비교 영역) -->
                    <TextBlock Grid.Row="4"
                               Text="스터디 목록"
                               Style="{StaticResource HnVue.UppercaseLabel}"
                               Margin="0,8,0,4"/>
                    <Border Grid.Row="5"
                            Background="{DynamicResource HnVue.Semantic.Surface.Page}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1" CornerRadius="4">
                        <DataGrid ItemsSource="{Binding PreviewStudiesA}"
                                  SelectedItem="{Binding SelectedPreviewStudy}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource HnVue.Component.DataGrid.GridLine}"
                                  ColumnHeaderStyle="{StaticResource MergeHeaderStyle}"
                                  RowStyle="{StaticResource MergeRowStyle}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                  FontSize="11" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                <DataGridTextColumn Header="Body Part" Binding="{Binding BodyPart}" Width="60"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding StudyDate}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════════════════ Patient B Lane ═══════════════════ -->
            <Border Grid.Column="1"
                    Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                    BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                    BorderThickness="0,0,1,0"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="120"/>
                    </Grid.RowDefinitions>

                    <!-- Lane header with checkbox -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Patient B"
                                       Style="{StaticResource HnVue.SectionHeader}"
                                       Foreground="{DynamicResource HnVue.Semantic.Brand.Accent}"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1"
                                  Content="Only WorkList"
                                  Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                  FontSize="11"
                                  FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding OnlyWorkListB}"/>
                    </Grid>

                    <!-- Search B row -->
                    <Border Grid.Row="1"
                            Height="32" CornerRadius="4"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1"
                            Margin="0,0,0,8"
                            Padding="8,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchQueryB, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                                     BorderThickness="0" FontSize="12"
                                     VerticalAlignment="Center"
                                     FontFamily="{DynamicResource HnVue.Core.FontFamily}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SearchBCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="2"
                                    Content="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding SearchBCommand}"
                                    Style="{StaticResource HnVue.OutlineButton}"
                                    Width="28" Height="26" Padding="0" FontSize="12"/>
                        </Grid>
                    </Border>

                    <!-- Patient B list -->
                    <TextBlock Grid.Row="2"
                               Text="환자 목록"
                               Style="{StaticResource HnVue.UppercaseLabel}"
                               Margin="0,0,0,4"/>
                    <ListBox Grid.Row="3"
                             ItemsSource="{Binding PatientsB}"
                             SelectedItem="{Binding SelectedPatientB}"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="{DynamicResource HnVue.Core.FontFamily}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Height" Value="44"/>
                                <Setter Property="Padding" Value="8,0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Border.Default}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource HnVue.Component.DataGrid.SelectionBg}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Brand.PrimaryLight}"/>
                                        <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Surface.Card}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold" FontSize="12"
                                               FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                                    <TextBlock Text="{Binding PatientId}"
                                               FontSize="11"
                                               Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                               FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Study list for Patient B -->
                    <TextBlock Grid.Row="4"
                               Text="스터디 목록"
                               Style="{StaticResource HnVue.UppercaseLabel}"
                               Margin="0,8,0,4"/>
                    <Border Grid.Row="5"
                            Background="{DynamicResource HnVue.Semantic.Surface.Page}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1" CornerRadius="4">
                        <DataGrid ItemsSource="{Binding PreviewStudiesB}"
                                  SelectedItem="{Binding SelectedPreviewStudy}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource HnVue.Component.DataGrid.GridLine}"
                                  ColumnHeaderStyle="{StaticResource MergeHeaderStyle}"
                                  RowStyle="{StaticResource MergeRowStyle}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                  FontSize="11" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                <DataGridTextColumn Header="Body Part" Binding="{Binding BodyPart}" Width="60"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding StudyDate}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════════════════ Preview Panel (Larger) ═══════════════════ -->
            <Border Grid.Column="2"
                    Background="{DynamicResource HnVue.Semantic.Surface.Page}"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="100"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Preview"
                               Style="{StaticResource HnVue.SectionHeader}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <!-- PPT Slide 13: A/B 비교 preview (larger) -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Image A preview -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                                BorderThickness="1"
                                Margin="0,0,0,4"
                                CornerRadius="4">
                            <Grid>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8B9;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="36"
                                               Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Patient A"
                                               FontSize="11"
                                               Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                               HorizontalAlignment="Center"
                                               FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <!-- Overlay info (PPT: 환자 ID, 검사 일자) -->
                                <Border VerticalAlignment="Bottom"
                                        Background="#80000000"
                                        Padding="8,4"
                                        CornerRadius="0,0,4,4">
                                    <TextBlock Text="{Binding SelectedPatientA.Name}"
                                               Foreground="White"
                                               FontSize="10"
                                               FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Image B preview -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                                BorderThickness="1"
                                Margin="0,4,0,0"
                                CornerRadius="4">
                            <Grid>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8B9;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="36"
                                               Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Patient B"
                                               FontSize="11"
                                               Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                               HorizontalAlignment="Center"
                                               FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <Border VerticalAlignment="Bottom"
                                        Background="#80000000"
                                        Padding="8,4"
                                        CornerRadius="0,0,4,4">
                                    <TextBlock Text="{Binding SelectedPatientB.Name}"
                                               Foreground="White"
                                               FontSize="10"
                                               FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- PPT notes: 중앙 thumbnail 영역 (Preview 하단) -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="0,1,0,0"
                            Padding="4"
                            Margin="0,8,0,0">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding PreviewStudiesA}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="80" Height="80"
                                                Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                                                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Margin="0,0,4,0"
                                                ToolTip="{Binding Description}">
                                            <Grid>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="&#xE8B9;"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="24"
                                                               Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding BodyPart}"
                                                               FontSize="9"
                                                               Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                                               HorizontalAlignment="Center"
                                                               FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <!-- Date overlay -->
                                                <Border VerticalAlignment="Bottom"
                                                        Background="#80000000"
                                                        Padding="4,2"
                                                        CornerRadius="0,0,4,4">
                                                    <TextBlock Text="{Binding StudyDate}"
                                                               Foreground="White"
                                                               FontSize="8"
                                                               FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ Bottom action bar ═══ -->
        <Border Grid.Row="2"
                Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Error message -->
                <TextBlock Grid.Column="0"
                           Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource HnVue.Semantic.Status.Emergency}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                <!-- Sync toggle (PPT notes: Sync on/off) -->
                <ToggleButton Grid.Column="1"
                              Content="&#xE895; Sync"
                              FontFamily="Segoe MDL2 Assets"
                              FontSize="12"
                              IsChecked="{Binding IsSyncEnabled}"
                              Style="{StaticResource HnVue.OutlineButton}"
                              Width="90" Height="36"
                              Margin="0,0,8,0"/>

                <Button Grid.Column="2"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource HnVue.OutlineButton}"
                        Width="100" Height="36"
                        Margin="0,0,8,0"
                        FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>

                <Button Grid.Column="3"
                        Content="Sync Study"
                        Command="{Binding MergeCommand}"
                        Style="{StaticResource HnVue.PrimaryButton}"
                        Width="120" Height="36"
                        FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
