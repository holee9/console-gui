<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:HnVue.UI.Components.Medical">

    <!-- ═══════════════════════════════════════════════════════════
         Patient Info Card Component
         Displays patient information for medical imaging workflow
         ═══════════════════════════════════════════════════════════ -->

    <Style TargetType="local:PatientInfoCard">
        <Setter Property="Background" Value="{StaticResource DS2026.Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource DS2026.Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="{StaticResource DS2026.Padding.MD}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PatientInfoCard">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource DS2026.CornerRadius.LG}"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0"
                                    Padding="0,0,0,12"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{StaticResource DS2026.Brush.Border}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Patient Icon -->
                                    <Ellipse Grid.Column="0"
                                             Width="40"
                                             Height="40"
                                             Fill="{StaticResource DS2026.Brush.Primary.Light}">
                                        <Ellipse.OpacityMask>
                                            <VisualBrush Stretch="Fill">
                                                <VisualBrush.Visual>
                                                    <Path Data="M12,12 C12,14.209 14.239,16 17,16 C19.761,16 22,14.209 22,12 C22,9.791 19.761,8 17,8 C14.239,8 12,9.791 12,12 Z M8,12 C8,12 8,8 12,8 C12,8 12,4 17,4 C22,4 22,8 22,8 C26,8 26,12 26,12 C28,12 28,16 26,18 C26,20 22,22 17,22 C12,22 8,20 8,18 C6,16 6,12 8,12 Z"
                                                          Fill="White" />
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Ellipse.OpacityMask>
                                    </Ellipse>

                                    <!-- Patient Info -->
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="{TemplateBinding PatientName}"
                                                   FontSize="{StaticResource DS2026.FontSize.H3}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource DS2026.Brush.Text}" />

                                        <TextBlock Text="{TemplateBinding PatientId}"
                                                   FontSize="{StaticResource DS2026.FontSize.Caption}"
                                                   Foreground="{StaticResource DS2026.Brush.TextMuted}" />
                                    </StackPanel>

                                    <!-- Emergency Indicator -->
                                    <Border Grid.Column="2"
                                            Visibility="{TemplateBinding IsEmergency, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Background="{StaticResource DS2026.Brush.Error}"
                                            CornerRadius="{StaticResource DS2026.CornerRadius.SM}"
                                            Padding="8,4">
                                        <TextBlock Text="EMERGENCY"
                                                   FontSize="{StaticResource DS2026.FontSize.Caption}"
                                                   FontWeight="Bold"
                                                   Foreground="White" />
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Details -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="0,12,0,0">
                                <StackPanel>
                                    <!-- Birth Date & Sex -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Birth Date"
                                                       FontSize="{StaticResource DS2026.FontSize.Caption}"
                                                       Foreground="{StaticResource DS2026.Brush.TextMuted}" />
                                            <TextBlock Text="{TemplateBinding BirthDate}"
                                                       FontSize="{StaticResource DS2026.FontSize.Body}"
                                                       Foreground="{StaticResource DS2026.Brush.Text}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="Sex"
                                                       FontSize="{StaticResource DS2026.FontSize.Caption}"
                                                       Foreground="{StaticResource DS2026.Brush.TextMuted}" />
                                            <TextBlock Text="{TemplateBinding Sex}"
                                                       FontSize="{StaticResource DS2026.FontSize.Body}"
                                                       Foreground="{StaticResource DS2026.Brush.Text}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Age -->
                                    <StackPanel Margin="0,0,0,12" Visibility="{TemplateBinding Age, Converter={StaticResource NullToVisibilityConverter}}">
                                        <TextBlock Text="Age"
                                                   FontSize="{StaticResource DS2026.FontSize.Caption}"
                                                   Foreground="{StaticResource DS2026.Brush.TextMuted}" />
                                        <TextBlock Text="{TemplateBinding Age}"
                                                   FontSize="{StaticResource DS2026.FontSize.Body}"
                                                   Foreground="{StaticResource DS2026.Brush.Text}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>

                                    <!-- Accession Number -->
                                    <StackPanel Margin="0,0,0,12" Visibility="{TemplateBinding AccessionNumber, Converter={StaticResource NullToVisibilityConverter}}">
                                        <TextBlock Text="Accession No"
                                                   FontSize="{StaticResource DS2026.FontSize.Caption}"
                                                   Foreground="{StaticResource DS2026.Brush.TextMuted}" />
                                        <TextBlock Text="{TemplateBinding AccessionNumber}"
                                                   FontSize="{StaticResource DS2026.FontSize.Body}"
                                                   Foreground="{StaticResource DS2026.Brush.Text}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>

                                    <!-- Study Date -->
                                    <StackPanel Visibility="{TemplateBinding StudyDate, Converter={StaticResource NullToVisibilityConverter}}">
                                        <TextBlock Text="Study Date"
                                                   FontSize="{StaticResource DS2026.FontSize.Caption}"
                                                   Foreground="{StaticResource DS2026.Brush.TextMuted}" />
                                        <TextBlock Text="{TemplateBinding StudyDate}"
                                                   FontSize="{StaticResource DS2026.FontSize.Body}"
                                                   Foreground="{StaticResource DS2026.Brush.Text}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
