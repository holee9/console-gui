<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         DS2026 Card Styles
         Consistent surface containers for content grouping
         ═══════════════════════════════════════════════════════════ -->

    <!-- ═══ Card Base Control ═══ -->
    <Style x:Key="DS2026.Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DS2026.Brush.Surface}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource DS2026.CornerRadius.LG}" />
        <Setter Property="Padding" Value="{StaticResource DS2026.Padding.MD}" />
        <Setter Property="Margin" Value="{StaticResource DS2026.Spacing.SM}" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="Black"
                                  BlurRadius="12"
                                  ShadowDepth="0"
                                  Opacity="0.3" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ Card with Border ═══ -->
    <Style x:Key="DS2026.Card.Bordered" TargetType="Border" BasedOn="{StaticResource DS2026.Card}">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource DS2026.Brush.Border}" />
    </Style>

    <!-- ═══ Interactive Card (Hover Effect) ═══ -->
    <Style x:Key="DS2026.Card.Interactive" TargetType="Border" BasedOn="{StaticResource DS2026.Card.Bordered}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource DS2026.Brush.Primary}" />
                <Setter Property="Background" Value="#2A2A4A" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══ Selected Card ═══ -->
    <Style x:Key="DS2026.Card.Selected" TargetType="Border" BasedOn="{StaticResource DS2026.Card.Bordered}">
        <Setter Property="BorderBrush" Value="{StaticResource DS2026.Brush.Primary}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Background" Value="#2A2A4A" />
    </Style>

</ResourceDictionary>
