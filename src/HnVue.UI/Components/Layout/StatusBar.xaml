<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:HnVue.UI.Components.Layout">

    <!-- ═══════════════════════════════════════════════════════════
         Status Bar Component
         Displays system status, connection info, and notifications
         ═══════════════════════════════════════════════════════════ -->

    <Style TargetType="local:StatusBar">
        <Setter Property="Background" Value="{StaticResource DS2026.Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource DS2026.Brush.Border}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:StatusBar">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Height="{TemplateBinding Height}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Left: Status Items -->
                            <ItemsControl Grid.Column="0"
                                          ItemsSource="{TemplateBinding StatusItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style>
                                        <Setter Property="FrameworkElement.Margin" Value="0,0,16,0" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                            </ItemsControl>

                            <!-- Center: Message -->
                            <TextBlock Grid.Column="1"
                                       Text="{TemplateBinding Message}"
                                       Foreground="{StaticResource DS2026.Brush.TextMuted}"
                                       FontSize="{StaticResource DS2026.FontSize.Caption}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />

                            <!-- Right: Info Items -->
                            <ItemsControl Grid.Column="2"
                                          ItemsSource="{TemplateBinding InfoItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style>
                                        <Setter Property="FrameworkElement.Margin" Value="16,0,0,0" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Status Item Style -->
    <Style TargetType="ContentControl" x:Key="DS2026.StatusItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Status Indicator -->
                        <Ellipse Width="8" Height="8"
                                 Fill="{Binding StatusBrush, RelativeSource={RelativeSource AncestorType=local:StatusBarItem}}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPulse, RelativeSource={RelativeSource AncestorType=local:StatusBarItem}}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Opacity)"
                                                                       From="0.3" To="1" Duration="0:0:1"
                                                                       AutoReverse="True" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <!-- Text -->
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{StaticResource DS2026.Brush.TextMuted}"
                                   FontSize="{StaticResource DS2026.FontSize.Caption}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
