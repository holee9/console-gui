{
  "metadata": [
    {
      "src": [
        {
          "files": ["src/**/*.csproj"],
          "exclude": ["**/bin/**", "**/obj/**"]
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net8.0-windows"
      },
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": [
          "docs/docfx/articles/**.md",
          "docs/docfx/articles/**/toc.yml",
          "docs/docfx/toc.yml",
          "docs/docfx/*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": ["docs/docfx/images/**"]
      }
    ],
    "dest": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appTitle": "HnVue Console SW",
      "_appFooter": "© 2026 H&abyz — HnVue Console SW API Documentation",
      "_enableSearch": true,
      "_disableContribution": true
    },
    "postProcessors": [],
    "markdownEngineName": "markdig",
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false
  }
}
