<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         High-Contrast Theme — Core Token Overrides
         Industrial high-contrast for clinical/operating-room use.
         Designed for bright ambient light and viewing angle extremes.
         IEC 62366 safety-critical status colors: maximum distinguishability.
         All status colors are pure saturated hues per clinical standard.
         ═══════════════════════════════════════════════════════════ -->

    <!-- ═══ Brand Colors ═══ -->
    <Color x:Key="HnVue.Core.Color.Primary">#0050FF</Color>
    <Color x:Key="HnVue.Core.Color.PrimaryLight">#4488FF</Color>
    <Color x:Key="HnVue.Core.Color.Accent">#00FFFF</Color>

    <!-- ═══ Background Colors ═══ -->
    <Color x:Key="HnVue.Core.Color.BackgroundPage">#000000</Color>
    <Color x:Key="HnVue.Core.Color.BackgroundPanel">#0A0A0A</Color>
    <Color x:Key="HnVue.Core.Color.BackgroundCard">#111111</Color>

    <!-- ═══ Text Colors ═══ -->
    <Color x:Key="HnVue.Core.Color.TextPrimary">#FFFFFF</Color>
    <Color x:Key="HnVue.Core.Color.TextSecondary">#E0E0E0</Color>
    <Color x:Key="HnVue.Core.Color.TextDisabled">#808080</Color>

    <!-- ═══ Status Colors (IEC 62366 — High Contrast / Clinical) ═══
         Safe/Idle  : #00FF00 (pure green — maximum clinical visibility)
         Warning    : #FFFF00 (pure yellow — unambiguous caution signal)
         Blocked    : #FF8800 (pure orange — distinct from Warning)
         Emergency  : #FF0000 (pure red — universal emergency signal)

         These are the maximum-saturation values for operating-room displays
         and bright ambient environments per IEC 62366 guidance.
    ═══ -->
    <Color x:Key="HnVue.Core.Color.StatusSafe">#00FF00</Color>
    <Color x:Key="HnVue.Core.Color.StatusWarning">#FFFF00</Color>
    <Color x:Key="HnVue.Core.Color.StatusBlocked">#FF8800</Color>
    <Color x:Key="HnVue.Core.Color.StatusEmergency">#FF0000</Color>

    <!-- ═══ Interactive Colors ═══ -->
    <Color x:Key="HnVue.Core.Color.ButtonPrimary">#0050FF</Color>
    <Color x:Key="HnVue.Core.Color.ButtonPrimaryHover">#4488FF</Color>
    <Color x:Key="HnVue.Core.Color.ButtonSecondary">Transparent</Color>
    <Color x:Key="HnVue.Core.Color.ButtonDanger">#FF0000</Color>

    <!-- ═══ Border Colors ═══ -->
    <Color x:Key="HnVue.Core.Color.Border">#FFFFFF</Color>
    <Color x:Key="HnVue.Core.Color.BorderFocus">#00FFFF</Color>

</ResourceDictionary>
