<UserControl x:Class="HnVue.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:HnVue.UI.Converters"
             xmlns:dt="clr-namespace:HnVue.UI.DesignTime"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance dt:DesignTimeSettingsViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="720" d:DesignWidth="1024"
             AutomationProperties.Name="Settings View">
    <!--
        @MX:NOTE SettingsView — Application settings dialog with TOP-tab navigation.
                 PPT Slides 14~22: menus moved from left sidebar to top row.
                 Network tab consolidates PACS + Worklist + Print (was 3 separate tabs).
                 "Login Popup" renamed to "Access Notice" (System tab).
                 "Only No matching" renamed to "Un-Matched" (RIS Code sub-tab).
                 Account: Operator field removed; Role is ComboBox.
    -->
    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <!-- ActiveTabToVisibilityConverter: returns Visible when ActiveTab == ConverterParameter -->
        <converters:ActiveTabToVisibilityConverter x:Key="ActiveTabToVisibility"/>
        <!-- StringEqualityToBoolConverter: returns true when ActiveTab == ConverterParameter (for IsChecked) -->
        <converters:StringEqualityToBoolConverter x:Key="StringEqualityToBool"/>

        <!-- Tab button style: underline highlight when IsChecked -->
        <Style x:Key="SettingsTabButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Secondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="MinWidth" Value="44"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="IsTabStop" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Brand.Accent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Brand.Accent}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sub-tab button (smaller, for RIS Code sub-tabs) -->
        <Style x:Key="RisSubTabButton" TargetType="ToggleButton" BasedOn="{StaticResource SettingsTabButton}">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Section label -->
        <Style x:Key="SettingsSectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Secondary}"/>
            <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Row label (160 px wide) -->
        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
            <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="160"/>
        </Style>

        <!-- Standard input TextBox -->
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}"/>
            <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Surface.Card}"/>
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Border.Default}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="IsTabStop" Value="True"/>
        </Style>

        <!-- Standard ComboBox for settings forms -->
        <Style x:Key="SettingsComboBox" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}"/>
            <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Surface.Card}"/>
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Border.Default}"/>
            <Setter Property="IsTabStop" Value="True"/>
        </Style>

        <!-- Standard CheckBox for settings forms -->
        <Style x:Key="SettingsCheckBox" TargetType="CheckBox">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}"/>
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="IsTabStop" Value="True"/>
        </Style>

        <!-- Settings form row: label + input in a grid -->
        <Style x:Key="SettingsFormRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource HnVue.Semantic.Surface.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Tab row -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Action bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                BorderThickness="0,0,0,1"
                Padding="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE713;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="16"
                           Foreground="{DynamicResource HnVue.Semantic.Brand.Accent}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBlock Text="Settings"
                           Style="{StaticResource HnVue.SectionHeader}"
                           VerticalAlignment="Center"
                           AutomationProperties.Name="Settings Header"/>
            </StackPanel>
        </Border>

        <!-- Tab Row: TOP navigation per PPT Slide 14 -->
        <Border Grid.Row="1"
                Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <ToggleButton Content="System"
                                  Style="{StaticResource SettingsTabButton}"
                                  AutomationProperties.Name="System Tab"
                                  TabIndex="1"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=System, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="System"/>
                    <ToggleButton Content="Account"
                                  Style="{StaticResource SettingsTabButton}"
                                  AutomationProperties.Name="Account Tab"
                                  TabIndex="2"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Account, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="Account"/>
                    <ToggleButton Content="Detector"
                                  Style="{StaticResource SettingsTabButton}"
                                  AutomationProperties.Name="Detector Tab"
                                  TabIndex="3"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Detector, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="Detector"/>
                    <ToggleButton Content="Generator"
                                  Style="{StaticResource SettingsTabButton}"
                                  AutomationProperties.Name="Generator Tab"
                                  TabIndex="4"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Generator, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="Generator"/>
                    <!-- Network: PPT consolidates PACS + Worklist + Print here -->
                    <ToggleButton Content="Network"
                                  Style="{StaticResource SettingsTabButton}"
                                  AutomationProperties.Name="Network Tab"
                                  TabIndex="5"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Network, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="Network"/>
                    <ToggleButton Content="Display"
                                  Style="{StaticResource SettingsTabButton}"
                                  AutomationProperties.Name="Display Tab"
                                  TabIndex="6"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Display, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="Display"/>
                    <ToggleButton Content="Option"
                                  Style="{StaticResource SettingsTabButton}"
                                  AutomationProperties.Name="Option Tab"
                                  TabIndex="7"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Option, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="Option"/>
                    <ToggleButton Content="Database"
                                  Style="{StaticResource SettingsTabButton}"
                                  AutomationProperties.Name="Database Tab"
                                  TabIndex="8"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Database, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="Database"/>
                    <ToggleButton Content="DicomSet"
                                  Style="{StaticResource SettingsTabButton}"
                                  AutomationProperties.Name="DicomSet Tab"
                                  TabIndex="9"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=DicomSet, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="DicomSet"/>
                    <!-- RIS Code: has Matching / Un-Matched sub-tabs -->
                    <ToggleButton Content="RIS Code"
                                  Style="{StaticResource SettingsTabButton}"
                                  AutomationProperties.Name="RIS Code Tab"
                                  TabIndex="10"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=RIS Code, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="RIS Code"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Content Area -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="24,20,24,20">

                <!-- SYSTEM tab (PPT Slide 14) -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=System}">

                    <TextBlock Text="NOTICE" Style="{StaticResource SettingsSectionLabel}"/>

                    <!-- Access Notice textarea (PPT: renamed from "Login Popup") -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Style="{StaticResource InputLabel}"
                                   Text="Access Notice"
                                   Margin="0,0,0,6"
                                   AutomationProperties.Name="Access Notice Label"/>
                        <TextBox Text="{Binding AccessNoticeText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}"
                                 Height="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 Padding="8,6"
                                 TabIndex="11"
                                 AutomationProperties.Name="Access Notice Text"
                                 AutomationProperties.HelpText="Text shown when a session starts"/>
                    </StackPanel>

                    <Separator Background="{DynamicResource HnVue.Semantic.Border.Default}" Margin="0,0,0,16"/>
                    <TextBlock Text="SYSTEM" Style="{StaticResource SettingsSectionLabel}"/>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Priority"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource SettingsComboBox}"
                                  TabIndex="12"
                                  AutomationProperties.Name="System Priority">
                            <ComboBoxItem Content="Normal" IsSelected="True"/>
                            <ComboBoxItem Content="High"/>
                        </ComboBox>
                    </Grid>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Language"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource SettingsComboBox}"
                                  TabIndex="13"
                                  AutomationProperties.Name="System Language">
                            <ComboBoxItem Content="Korean" IsSelected="True"/>
                            <ComboBoxItem Content="English"/>
                        </ComboBox>
                    </Grid>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Auto Logout (min)"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource SettingsTextBox}"
                                 Text="30"
                                 TabIndex="14"
                                 AutomationProperties.Name="Auto Logout Minutes"/>
                    </Grid>
                </StackPanel>

                <!-- ACCOUNT tab (PPT Slide 15) -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Account}">

                    <TextBlock Text="NEW ACCOUNT" Style="{StaticResource SettingsSectionLabel}"/>

                    <!-- Account ID -->
                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Account ID"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding NewAccountId, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}"
                                 TabIndex="20"
                                 AutomationProperties.Name="New Account ID"/>
                    </Grid>

                    <!-- Password -->
                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Password"/>
                        <PasswordBox Grid.Column="1"
                                     MinHeight="34"
                                     FontSize="12"
                                     FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                     Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                                     Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                                     BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                                     BorderThickness="1"
                                     TabIndex="21"
                                     AutomationProperties.Name="New Account Password"/>
                    </Grid>

                    <!-- Role ComboBox (PPT: Operator field removed, role now a dropdown) -->
                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Role"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource SettingsComboBox}"
                                  ItemsSource="{Binding AvailableRoles}"
                                  SelectedItem="{Binding NewAccountRole}"
                                  TabIndex="22"
                                  AutomationProperties.Name="New Account Role"/>
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="1"
                                Content="Add Account"
                                Style="{StaticResource HnVue.OutlineButton}"
                                MinHeight="36" Padding="16,0" FontSize="11"
                                FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                TabIndex="23"
                                AutomationProperties.Name="Add Account Button"/>
                    </Grid>

                    <Separator Background="{DynamicResource HnVue.Semantic.Border.Default}" Margin="0,0,0,16"/>
                    <TextBlock Text="ACCOUNT LIST" Style="{StaticResource SettingsSectionLabel}"/>

                    <!-- Account list DataGrid -->
                    <DataGrid MinHeight="160"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                              BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                              BorderThickness="1"
                              FontSize="12"
                              FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                              TabIndex="24"
                              AutomationProperties.Name="Account List">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Account ID" Width="*" Binding="{Binding AccountId}"/>
                            <DataGridTextColumn Header="Role" Width="120" Binding="{Binding Role}"/>
                            <DataGridTextColumn Header="Created" Width="140" Binding="{Binding CreatedDate}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>

                <!-- DETECTOR tab (PPT Slide 16) -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Detector}">
                    <TextBlock Text="DETECTOR SETTINGS" Style="{StaticResource SettingsSectionLabel}"/>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Detector Type"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource SettingsComboBox}"
                                  TabIndex="30"
                                  AutomationProperties.Name="Detector Type">
                            <ComboBoxItem Content="CsI FPD" IsSelected="True"/>
                            <ComboBoxItem Content="GOS FPD"/>
                        </ComboBox>
                    </Grid>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Connection"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource SettingsComboBox}"
                                  TabIndex="31"
                                  AutomationProperties.Name="Detector Connection Type">
                            <ComboBoxItem Content="Ethernet" IsSelected="True"/>
                            <ComboBoxItem Content="Wi-Fi"/>
                        </ComboBox>
                    </Grid>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="IP Address"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource SettingsTextBox}"
                                 Text="192.168.1.10"
                                 TabIndex="32"
                                 AutomationProperties.Name="Detector IP Address"/>
                    </Grid>

                    <Separator Background="{DynamicResource HnVue.Semantic.Border.Default}" Margin="0,4,0,16"/>
                    <TextBlock Text="CALIBRATION" Style="{StaticResource SettingsSectionLabel}"/>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Last Calibration"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource SettingsTextBox}"
                                 Text="2026-04-01"
                                 IsReadOnly="True"
                                 TabIndex="33"
                                 AutomationProperties.Name="Last Calibration Date"/>
                        <Button Grid.Column="2"
                                Content="Calibrate"
                                Style="{StaticResource HnVue.OutlineButton}"
                                MinHeight="34" Padding="12,0" FontSize="11"
                                FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                Margin="8,0,0,0"
                                TabIndex="34"
                                AutomationProperties.Name="Run Calibration"/>
                    </Grid>
                </StackPanel>

                <!-- GENERATOR tab (PPT Slide 17) -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Generator}">
                    <TextBlock Text="GENERATOR SETTINGS" Style="{StaticResource SettingsSectionLabel}"/>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Generator Model"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource SettingsComboBox}"
                                  TabIndex="40"
                                  AutomationProperties.Name="Generator Model">
                            <ComboBoxItem Content="Model A" IsSelected="True"/>
                            <ComboBoxItem Content="Model B"/>
                        </ComboBox>
                    </Grid>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Connection Port"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource SettingsComboBox}"
                                  TabIndex="41"
                                  AutomationProperties.Name="Generator Connection Port">
                            <ComboBoxItem Content="COM1" IsSelected="True"/>
                            <ComboBoxItem Content="COM2"/>
                            <ComboBoxItem Content="COM3"/>
                        </ComboBox>
                    </Grid>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Baud Rate"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource SettingsComboBox}"
                                  TabIndex="42"
                                  AutomationProperties.Name="Generator Baud Rate">
                            <ComboBoxItem Content="9600" IsSelected="True"/>
                            <ComboBoxItem Content="19200"/>
                            <ComboBoxItem Content="115200"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <!-- NETWORK tab (PPT Slide 18): PACS + Worklist + Print merged -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Network}">

                    <!-- PACS section -->
                    <TextBlock Text="PACS" Style="{StaticResource SettingsSectionLabel}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Server Address"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding PacsServerAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}" Margin="0,0,6,0"
                                 TabIndex="50"
                                 AutomationProperties.Name="PACS Server Address"/>
                        <TextBox Grid.Column="2"
                                 Text="{Binding PacsServerPort, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}" Margin="0,0,6,0"
                                 TabIndex="51"
                                 AutomationProperties.Name="PACS Server Port"/>
                        <Button Grid.Column="3" Content="Add"
                                Style="{StaticResource HnVue.OutlineButton}"
                                MinHeight="34" Padding="10,0" FontSize="11"
                                Margin="0,0,4,0"
                                FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                TabIndex="52"
                                AutomationProperties.Name="Add PACS Server"/>
                        <Button Grid.Column="4" Content="Edit"
                                Style="{StaticResource HnVue.OutlineButton}"
                                MinHeight="34" Padding="10,0" FontSize="11"
                                FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                TabIndex="53"
                                AutomationProperties.Name="Edit PACS Server"/>
                    </Grid>
                    <Border MinHeight="70" Margin="0,0,0,20"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1">
                        <TextBlock Text="PACS server list"
                                   Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                   FontSize="11" FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <Separator Background="{DynamicResource HnVue.Semantic.Border.Default}" Margin="0,0,0,16"/>

                    <!-- Worklist section -->
                    <TextBlock Text="WORKLIST" Style="{StaticResource SettingsSectionLabel}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Server Address"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding WorklistServerAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}" Margin="0,0,6,0"
                                 TabIndex="54"
                                 AutomationProperties.Name="Worklist Server Address"/>
                        <TextBox Grid.Column="2"
                                 Text="{Binding WorklistServerPort, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}" Margin="0,0,6,0"
                                 TabIndex="55"
                                 AutomationProperties.Name="Worklist Server Port"/>
                        <Button Grid.Column="3" Content="Add"
                                Style="{StaticResource HnVue.OutlineButton}"
                                MinHeight="34" Padding="10,0" FontSize="11"
                                Margin="0,0,4,0"
                                FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                TabIndex="56"
                                AutomationProperties.Name="Add Worklist Server"/>
                        <Button Grid.Column="4" Content="Edit"
                                Style="{StaticResource HnVue.OutlineButton}"
                                MinHeight="34" Padding="10,0" FontSize="11"
                                FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                TabIndex="57"
                                AutomationProperties.Name="Edit Worklist Server"/>
                    </Grid>
                    <Border MinHeight="70" Margin="0,0,0,20"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1">
                        <TextBlock Text="Worklist server list"
                                   Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                   FontSize="11" FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <Separator Background="{DynamicResource HnVue.Semantic.Border.Default}" Margin="0,0,0,16"/>

                    <!-- Print section -->
                    <TextBlock Text="PRINT" Style="{StaticResource SettingsSectionLabel}"/>
                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Printer"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource SettingsComboBox}"
                                  TabIndex="58"
                                  AutomationProperties.Name="Printer Selection">
                            <ComboBoxItem Content="Default Printer" IsSelected="True"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <!-- DISPLAY tab (PPT Slide 19) -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Display}">
                    <TextBlock Text="DISPLAY SETTINGS" Style="{StaticResource SettingsSectionLabel}"/>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Theme"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource SettingsComboBox}"
                                  TabIndex="60"
                                  AutomationProperties.Name="Display Theme">
                            <ComboBoxItem Content="Dark" IsSelected="True"/>
                            <ComboBoxItem Content="Light"/>
                            <ComboBoxItem Content="High Contrast"/>
                        </ComboBox>
                    </Grid>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Window Mode"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource SettingsComboBox}"
                                  TabIndex="61"
                                  AutomationProperties.Name="Window Mode">
                            <ComboBoxItem Content="Full Screen" IsSelected="True"/>
                            <ComboBoxItem Content="Windowed"/>
                        </ComboBox>
                    </Grid>

                    <CheckBox Content="Show Patient Info Overlay"
                              Style="{StaticResource SettingsCheckBox}"
                              IsChecked="True"
                              Margin="0,0,0,8"
                              TabIndex="62"
                              AutomationProperties.Name="Show Patient Info Overlay"/>

                    <CheckBox Content="Show Annotation Tools"
                              Style="{StaticResource SettingsCheckBox}"
                              IsChecked="True"
                              Margin="0,0,0,8"
                              TabIndex="63"
                              AutomationProperties.Name="Show Annotation Tools"/>
                </StackPanel>

                <!-- OPTION tab (PPT Slide 20) -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Option}">
                    <TextBlock Text="OPTIONS" Style="{StaticResource SettingsSectionLabel}"/>

                    <CheckBox Content="Auto-receive images from PACS"
                              Style="{StaticResource SettingsCheckBox}"
                              IsChecked="True"
                              Margin="0,0,0,8"
                              TabIndex="70"
                              AutomationProperties.Name="Auto-receive Images"/>

                    <CheckBox Content="Auto-print after acquisition"
                              Style="{StaticResource SettingsCheckBox}"
                              Margin="0,0,0,8"
                              TabIndex="71"
                              AutomationProperties.Name="Auto-print After Acquisition"/>

                    <CheckBox Content="Confirm before delete"
                              Style="{StaticResource SettingsCheckBox}"
                              IsChecked="True"
                              Margin="0,0,0,8"
                              TabIndex="72"
                              AutomationProperties.Name="Confirm Before Delete"/>

                    <CheckBox Content="Enable audit logging"
                              Style="{StaticResource SettingsCheckBox}"
                              IsChecked="True"
                              Margin="0,0,0,8"
                              TabIndex="73"
                              AutomationProperties.Name="Enable Audit Logging"/>

                    <Separator Background="{DynamicResource HnVue.Semantic.Border.Default}" Margin="0,8,0,16"/>
                    <TextBlock Text="IMAGE PROCESSING" Style="{StaticResource SettingsSectionLabel}"/>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Default W/L"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource SettingsComboBox}"
                                  TabIndex="74"
                                  AutomationProperties.Name="Default Window Level">
                            <ComboBoxItem Content="Auto" IsSelected="True"/>
                            <ComboBoxItem Content="Chest"/>
                            <ComboBoxItem Content="Bone"/>
                            <ComboBoxItem Content="Abdomen"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <!-- DATABASE tab (PPT Slide 21) -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Database}">
                    <TextBlock Text="DATABASE SETTINGS" Style="{StaticResource SettingsSectionLabel}"/>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Database Path"/>
                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Style="{StaticResource SettingsTextBox}"
                                     Text="C:\HnVue\Data\hnvue.db"
                                     IsReadOnly="True"
                                     TabIndex="80"
                                     AutomationProperties.Name="Database File Path"/>
                            <Button Grid.Column="1"
                                    Content="Browse"
                                    Style="{StaticResource HnVue.OutlineButton}"
                                    MinHeight="34" Padding="12,0" FontSize="11"
                                    FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                    Margin="8,0,0,0"
                                    TabIndex="81"
                                    AutomationProperties.Name="Browse Database Path"/>
                        </Grid>
                    </Grid>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Backup Schedule"/>
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource SettingsComboBox}"
                                  TabIndex="82"
                                  AutomationProperties.Name="Database Backup Schedule">
                            <ComboBoxItem Content="Daily" IsSelected="True"/>
                            <ComboBoxItem Content="Weekly"/>
                            <ComboBoxItem Content="Manual"/>
                        </ComboBox>
                    </Grid>

                    <Separator Background="{DynamicResource HnVue.Semantic.Border.Default}" Margin="0,4,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="Backup Now"
                                Style="{StaticResource HnVue.OutlineButton}"
                                MinHeight="36" Padding="16,0" FontSize="11"
                                FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                Margin="0,0,8,0"
                                TabIndex="83"
                                AutomationProperties.Name="Backup Database Now"/>
                        <Button Grid.Column="1"
                                Content="Restore"
                                Style="{StaticResource HnVue.OutlineButton}"
                                MinHeight="36" Padding="16,0" FontSize="11"
                                FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                TabIndex="84"
                                AutomationProperties.Name="Restore Database"/>
                    </Grid>
                </StackPanel>

                <!-- DICOMSET tab (PPT Slide 22) -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=DicomSet}">
                    <TextBlock Text="DICOM SETTINGS" Style="{StaticResource SettingsSectionLabel}"/>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="AE Title"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource SettingsTextBox}"
                                 Text="HNVUE_SCU"
                                 TabIndex="90"
                                 AutomationProperties.Name="DICOM AE Title"/>
                    </Grid>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Station Name"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource SettingsTextBox}"
                                 Text="STATION01"
                                 TabIndex="91"
                                 AutomationProperties.Name="DICOM Station Name"/>
                    </Grid>

                    <Grid Style="{StaticResource SettingsFormRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Implementation UID"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource SettingsTextBox}"
                                 Text="1.2.840.113619.2.55"
                                 IsReadOnly="True"
                                 TabIndex="92"
                                 AutomationProperties.Name="DICOM Implementation UID"/>
                    </Grid>

                    <Separator Background="{DynamicResource HnVue.Semantic.Border.Default}" Margin="0,4,0,16"/>
                    <TextBlock Text="TRANSFER SYNTAX" Style="{StaticResource SettingsSectionLabel}"/>

                    <CheckBox Content="Implicit VR Little Endian (1.2.840.10008.1.2)"
                              Style="{StaticResource SettingsCheckBox}"
                              IsChecked="True"
                              Margin="0,0,0,8"
                              TabIndex="93"
                              AutomationProperties.Name="Implicit VR Little Endian"/>

                    <CheckBox Content="Explicit VR Little Endian (1.2.840.10008.1.2.1)"
                              Style="{StaticResource SettingsCheckBox}"
                              IsChecked="True"
                              Margin="0,0,0,8"
                              TabIndex="94"
                              AutomationProperties.Name="Explicit VR Little Endian"/>

                    <CheckBox Content="JPEG Lossless (1.2.840.10008.1.2.4.70)"
                              Style="{StaticResource SettingsCheckBox}"
                              Margin="0,0,0,8"
                              TabIndex="95"
                              AutomationProperties.Name="JPEG Lossless Transfer Syntax"/>
                </StackPanel>

                <!-- RIS CODE tab (PPT Slide 22 continued) -->
                <!-- PPT: "Only No matching" renamed to "Un-Matched" -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=RIS Code}">

                    <!-- RIS Code sub-tab row -->
                    <Border Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="0,0,0,1"
                            Margin="0,0,0,16"
                            Padding="0,2,0,0">
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton Content="Matching"
                                          Style="{StaticResource RisSubTabButton}"
                                          AutomationProperties.Name="RIS Matching Sub-Tab"
                                          TabIndex="100"
                                          IsChecked="{Binding ActiveRisTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Matching, Mode=OneWay}"
                                          Command="{Binding SelectTabCommand}"
                                          CommandParameter="Matching"/>
                            <!-- PPT: "Only No matching" renamed to "Un-Matched" -->
                            <ToggleButton Content="Un-Matched"
                                          Style="{StaticResource RisSubTabButton}"
                                          AutomationProperties.Name="RIS Un-Matched Sub-Tab"
                                          TabIndex="101"
                                          IsChecked="{Binding ActiveRisTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Un-Matched, Mode=OneWay}"
                                          Command="{Binding SelectTabCommand}"
                                          CommandParameter="Un-Matched"/>
                        </StackPanel>
                    </Border>

                    <!-- Matching sub-tab content -->
                    <StackPanel Visibility="{Binding ActiveRisTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Matching}">
                        <DataGrid MinHeight="200"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                                  BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                                  BorderThickness="1"
                                  FontSize="12"
                                  FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                  TabIndex="102"
                                  AutomationProperties.Name="RIS Matching Code List">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="RIS Code" Width="120" Binding="{Binding RisCode}"/>
                                <DataGridTextColumn Header="Body Part" Width="120" Binding="{Binding BodyPart}"/>
                                <DataGridTextColumn Header="Protocol" Width="*" Binding="{Binding Protocol}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                    <!-- Un-Matched sub-tab content (PPT: formerly "Only No matching") -->
                    <StackPanel Visibility="{Binding ActiveRisTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Un-Matched}">
                        <DataGrid MinHeight="200"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                                  BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                                  BorderThickness="1"
                                  FontSize="12"
                                  FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                  TabIndex="103"
                                  AutomationProperties.Name="RIS Un-Matched Code List">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="RIS Code" Width="120" Binding="{Binding RisCode}"/>
                                <DataGridTextColumn Header="Description" Width="*" Binding="{Binding Description}"/>
                                <DataGridTextColumn Header="Received" Width="140" Binding="{Binding ReceivedDate}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </StackPanel>

            </Grid>
        </ScrollViewer>

        <!-- Action Bar -->
        <Border Grid.Row="3"
                Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Error message -->
                <TextBlock Grid.Column="0"
                           Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource HnVue.Semantic.Status.Emergency}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"
                           AutomationProperties.Name="Error Message"/>

                <Button Grid.Column="1"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource HnVue.OutlineButton}"
                        Width="100" MinHeight="44"
                        Margin="0,0,8,0"
                        FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                        TabIndex="110"
                        AutomationProperties.Name="Cancel Settings"/>

                <Button Grid.Column="2"
                        Content="Save"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource HnVue.PrimaryButton}"
                        Width="100" MinHeight="44"
                        FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                        TabIndex="111"
                        AutomationProperties.Name="Save Settings"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
