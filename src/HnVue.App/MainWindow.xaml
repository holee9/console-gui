<mah:MetroWindow x:Class="HnVue.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:views="clr-namespace:HnVue.UI.Views;assembly=HnVue.UI"
                 Title="HnVue Console" Height="900" Width="1400"
                 Background="{StaticResource HnVue.Background.Dark.Brush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HnVue.Primary.Brush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="HnVue Console"
                           Foreground="{StaticResource HnVue.Text.Primary.Brush}"
                           VerticalAlignment="Center"
                           Margin="16,0"
                           FontSize="{StaticResource HnVue.FontSize.Large}"
                           FontFamily="{StaticResource HnVue.FontFamily}" />
                <!-- User info + Logout (visible when authenticated) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            Margin="0,0,16,0"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding CurrentUsername}"
                               Foreground="{StaticResource HnVue.Text.Primary.Brush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               FontFamily="{StaticResource HnVue.FontFamily}"/>
                    <TextBlock Text="{Binding CurrentRoleDisplay}"
                               Foreground="{StaticResource HnVue.Text.Secondary.Brush}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"
                               FontFamily="{StaticResource HnVue.FontFamily}"/>
                    <Button Content="로그아웃"
                            Command="{Binding LogoutCommand}"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">

            <!-- 3-column main layout (visible when authenticated) -->
            <Grid Visibility="{Binding IsMainContentVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Patient List -->
                <Border Grid.Column="0" Background="{StaticResource HnVue.Background.Panel.Brush}">
                    <views:PatientListView DataContext="{Binding PatientListViewModel}"/>
                </Border>

                <!-- Center Panel: Image Viewer -->
                <Border Grid.Column="1" Background="{StaticResource HnVue.Background.Dark.Brush}" Margin="2,0">
                    <views:ImageViewerView DataContext="{Binding ImageViewerViewModel}"/>
                </Border>

                <!-- Right Panel: Workflow + Dose -->
                <Border Grid.Column="2" Background="{StaticResource HnVue.Background.Panel.Brush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <views:WorkflowView Grid.Row="0" DataContext="{Binding WorkflowViewModel}"/>
                        <views:DoseDisplayView Grid.Row="1" DataContext="{Binding DoseDisplayViewModel}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Login overlay (visible when not authenticated) -->
            <Border Visibility="{Binding IsLoginVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="{StaticResource HnVue.Background.Dark.Brush}">
                <views:LoginView x:Name="LoginViewControl" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Footer: Status Bar -->
        <StatusBar Grid.Row="2" Background="{StaticResource HnVue.Background.Card.Brush}">
            <StatusBarItem>
                <TextBlock Text="{Binding ActiveNavItem, StringFormat='섹션: {0}', FallbackValue='준비'}"
                           Foreground="{StaticResource HnVue.Text.Secondary.Brush}"
                           FontSize="{StaticResource HnVue.FontSize.Small}"
                           FontFamily="{StaticResource HnVue.FontFamily}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</mah:MetroWindow>
