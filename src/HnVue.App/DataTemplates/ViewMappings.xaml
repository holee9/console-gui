<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:HnVue.UI.ViewModels;assembly=HnVue.UI.ViewModels"
                    xmlns:views="clr-namespace:HnVue.UI.Views;assembly=HnVue.UI">

    <!-- DataTemplate mappings: concrete ViewModel type → View type.
         WPF resolves these automatically when a ContentControl.Content is set
         to a matching ViewModel instance. -->

    <DataTemplate DataType="{x:Type vm:LoginViewModel}">
        <views:LoginView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:PatientListViewModel}">
        <views:PatientListView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:ImageViewerViewModel}">
        <views:ImageViewerView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:WorkflowViewModel}">
        <views:WorkflowView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:DoseDisplayViewModel}">
        <views:DoseDisplayView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:CDBurnViewModel}">
        <views:CDBurnView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:SystemAdminViewModel}">
        <views:SystemAdminView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:QuickPinLockViewModel}">
        <views:QuickPinLockView />
    </DataTemplate>

    <!-- PPT 슬라이드 7: Studylist with prev/next nav, PACS dropdown, period filters -->
    <DataTemplate DataType="{x:Type vm:StudylistViewModel}">
        <views:StudylistView />
    </DataTemplate>

    <!-- PPT 슬라이드 8: Merged Add Patient/Procedure dialog -->
    <DataTemplate DataType="{x:Type vm:AddPatientProcedureViewModel}">
        <views:AddPatientProcedureView />
    </DataTemplate>

    <!-- PPT 슬라이드 13: Sync Study (renamed from "Same Studylist") -->
    <DataTemplate DataType="{x:Type vm:MergeViewModel}">
        <views:MergeView />
    </DataTemplate>

    <!-- PPT 슬라이드 14~21: Settings with top tabs, Network consolidation -->
    <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
        <views:SettingsView />
    </DataTemplate>

</ResourceDictionary>
