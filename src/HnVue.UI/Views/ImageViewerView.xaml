<UserControl x:Class="HnVue.UI.Views.ImageViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Image Viewer" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Zoom In" Command="{Binding ZoomInCommand}" Width="80" Margin="0,0,4,0"/>
            <Button Content="Zoom Out" Command="{Binding ZoomOutCommand}" Width="80" Margin="0,0,4,0"/>
            <Button Content="Reset W/L" Command="{Binding ResetWindowCommand}" Width="80"/>
            <TextBlock Text="Zoom: " Margin="16,0,4,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ZoomFactor, StringFormat=P0}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Loading indicator — SWR-IP-020 / Issue #16 -->
        <ProgressBar Grid.Row="2" IsIndeterminate="True" Height="4" VerticalAlignment="Top"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Error message — SWR-NF-UX-025 / Issue #16 -->
        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="Red" VerticalAlignment="Top"
                   Margin="0,8,0,0"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Image display area — SWR-IP-020 / Issue #10 -->
        <Border Grid.Row="2" Background="#1A1A1A" CornerRadius="4" ClipToBounds="True">
            <!-- Placeholder shown when no image is loaded -->
            <TextBlock Text="No image loaded. Select a patient and complete acquisition workflow."
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Foreground="Gray" FontSize="14" TextWrapping="Wrap" Margin="32"
                       Visibility="{Binding IsImageLoaded, Converter={StaticResource BoolToVisibilityConverter},
                                    ConverterParameter=Invert}"/>
        </Border>

        <!-- Actual image rendered over the border when loaded -->
        <Image Grid.Row="2"
               Source="{Binding ImageSource}"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"
               Visibility="{Binding IsImageLoaded, Converter={StaticResource BoolToVisibilityConverter}}"/>
    </Grid>
</UserControl>
