<mah:MetroWindow x:Class="HnVue.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:views="clr-namespace:HnVue.UI.Views;assembly=HnVue.UI"
                 Title="HnVue Console" Height="900" Width="1400"
                 Background="{StaticResource HnVue.Background.Dark.Brush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HnVue.Primary.Brush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="HnVue Console"
                           Foreground="{StaticResource HnVue.Text.Primary.Brush}"
                           VerticalAlignment="Center"
                           Margin="16,0"
                           FontSize="{StaticResource HnVue.FontSize.Large}"
                           FontFamily="{StaticResource HnVue.FontFamily}" />
                <!-- User info + Logout (visible when authenticated) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            Margin="0,0,16,0"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding CurrentUsername}"
                               Foreground="{StaticResource HnVue.Text.Primary.Brush}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               FontFamily="{StaticResource HnVue.FontFamily}"/>
                    <TextBlock Text="{Binding CurrentRoleDisplay}"
                               Foreground="{StaticResource HnVue.Text.Secondary.Brush}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"
                               FontFamily="{StaticResource HnVue.FontFamily}"/>
                    <!-- Emergency button — SWR-NF-UX-026 (Safety-Critical, HAZ-RAD) / Issue #11
                         Must be visible at all times; 44×44px minimum; ≤2 touch access. -->
                    <Button Content="EMERGENCY"
                            Command="{Binding EmergencyCommand}"
                            Background="Red" Foreground="White" FontWeight="Bold"
                            MinWidth="110" MinHeight="36"
                            Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <Button Content="로그아웃"
                            Command="{Binding LogoutCommand}"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">

            <!-- 3-column main layout (visible when authenticated) -->
            <Grid Visibility="{Binding IsMainContentVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Patient List (Shell Region — resolved via DataTemplate) -->
                <Border Grid.Column="0" Background="{StaticResource HnVue.Background.Panel.Brush}">
                    <ContentControl Content="{Binding PatientListViewModel}"/>
                </Border>

                <!-- Center Panel: Image Viewer (Shell Region — resolved via DataTemplate) -->
                <Border Grid.Column="1" Background="{StaticResource HnVue.Background.Dark.Brush}" Margin="2,0">
                    <ContentControl Content="{Binding ImageViewerViewModel}"/>
                </Border>

                <!-- Right Panel: Workflow + Dose (Shell Regions — resolved via DataTemplate) -->
                <Border Grid.Column="2" Background="{StaticResource HnVue.Background.Panel.Brush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ContentControl Grid.Row="0" Content="{Binding WorkflowViewModel}"/>
                        <ContentControl Grid.Row="1" Content="{Binding DoseDisplayViewModel}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Login overlay (visible when not authenticated) -->
            <Border Visibility="{Binding IsLoginVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="{StaticResource HnVue.Background.Dark.Brush}">
                <views:LoginView x:Name="LoginViewControl" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- TLS Inactive Warning Banner — SWR-CS-079 (Security-related, HAZ-SEC) / Issue #13
             Permanent yellow banner shown when DICOM TLS is disabled. -->
        <Border Grid.Row="1" VerticalAlignment="Top" Background="#FFFF00" Padding="8,3"
                Visibility="{Binding IsTlsInactive, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="100">
            <TextBlock Text="⚠ TLS 비활성 — 네트워크 데이터가 암호화되지 않습니다. 설정에서 TLS를 활성화하십시오."
                       Foreground="Black" FontWeight="SemiBold" FontSize="12"/>
        </Border>

        <!-- Session Timeout Countdown Banner — SWR-CS-075 (Security-related) / Issue #14
             Shown in footer area 3 minutes before session expires. -->
        <Border Grid.Row="2" Background="#CC4400" Padding="8,2"
                Visibility="{Binding IsTimeoutWarningVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="100" VerticalAlignment="Bottom">
            <TextBlock Text="{Binding SessionTimeoutCountdown, StringFormat='세션 만료까지 {0}초 — 활동하거나 다시 로그인하십시오'}"
                       Foreground="White" FontSize="11"/>
        </Border>

        <!-- Footer: Status Bar -->
        <StatusBar Grid.Row="2" Background="{StaticResource HnVue.Background.Card.Brush}">
            <StatusBarItem>
                <TextBlock Text="{Binding ActiveNavItem, StringFormat='섹션: {0}', FallbackValue='준비'}"
                           Foreground="{StaticResource HnVue.Text.Secondary.Brush}"
                           FontSize="{StaticResource HnVue.FontSize.Small}"
                           FontFamily="{StaticResource HnVue.FontFamily}" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</mah:MetroWindow>
