<UserControl x:Class="HnVue.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:HnVue.UI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="900">
    <!--
        @MX:NOTE SettingsView — Application settings dialog with TOP-tab navigation.
                 PPT 슬라이드 14~21: menus moved from left sidebar to top row.
                 Network tab consolidates PACS + Worklist + Print (was 3 separate tabs).
                 "Login Popup" renamed to "Access Notice" (System tab).
                 "Only No matching" renamed to "Un-Matched" (RIS Code sub-tab).
                 Account: Operator field removed; Role is ComboBox.
    -->
    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <!-- ActiveTabToVisibilityConverter: returns Visible when ActiveTab == ConverterParameter -->
        <converters:ActiveTabToVisibilityConverter x:Key="ActiveTabToVisibility"/>
        <!-- StringEqualityToBoolConverter: returns true when ActiveTab == ConverterParameter (for IsChecked) -->
        <converters:StringEqualityToBoolConverter x:Key="StringEqualityToBool"/>

        <!-- Tab button style: underline highlight when IsChecked -->
        <Style x:Key="SettingsTabButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Secondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Brand.Accent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Brand.Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sub-tab button (smaller, for RIS Code sub-tabs) -->
        <Style x:Key="RisSubTabButton" TargetType="ToggleButton" BasedOn="{StaticResource SettingsTabButton}">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Section label -->
        <Style x:Key="SettingsSectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Secondary}"/>
            <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Row label (160 px wide) -->
        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
            <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="160"/>
        </Style>

        <!-- Standard input TextBox -->
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}"/>
            <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Surface.Card}"/>
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Border.Default}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource HnVue.Semantic.Surface.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Tab row -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Action bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════ Header ═══════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                BorderThickness="0,0,0,1"
                Padding="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE713;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="16"
                           Foreground="{DynamicResource HnVue.Semantic.Brand.Accent}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBlock Text="Settings"
                           Style="{StaticResource HnVue.SectionHeader}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════ Tab Row — TOP navigation per PPT ═══════════════════ -->
        <Border Grid.Row="1"
                Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <ToggleButton Content="System"
                                  Style="{StaticResource SettingsTabButton}"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=System, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="System"/>
                    <ToggleButton Content="Account"
                                  Style="{StaticResource SettingsTabButton}"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Account, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="Account"/>
                    <ToggleButton Content="Detector"
                                  Style="{StaticResource SettingsTabButton}"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Detector, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="Detector"/>
                    <ToggleButton Content="Generator"
                                  Style="{StaticResource SettingsTabButton}"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Generator, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="Generator"/>
                    <!-- Network: PPT consolidates PACS + Worklist + Print here -->
                    <ToggleButton Content="Network"
                                  Style="{StaticResource SettingsTabButton}"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Network, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="Network"/>
                    <ToggleButton Content="Display"
                                  Style="{StaticResource SettingsTabButton}"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Display, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="Display"/>
                    <ToggleButton Content="Option"
                                  Style="{StaticResource SettingsTabButton}"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Option, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="Option"/>
                    <ToggleButton Content="Database"
                                  Style="{StaticResource SettingsTabButton}"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Database, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="Database"/>
                    <ToggleButton Content="DicomSet"
                                  Style="{StaticResource SettingsTabButton}"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=DicomSet, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="DicomSet"/>
                    <!-- RIS Code: has Matching / Un-Matched sub-tabs -->
                    <ToggleButton Content="RIS Code"
                                  Style="{StaticResource SettingsTabButton}"
                                  IsChecked="{Binding ActiveTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=RIS Code, Mode=OneWay}"
                                  Command="{Binding SelectTabCommand}" CommandParameter="RIS Code"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════ Content Area ═══════════════════ -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="24,20,24,20">

                <!-- ─────── SYSTEM tab ─────── -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=System}">

                    <TextBlock Text="NOTICE" Style="{StaticResource SettingsSectionLabel}"/>

                    <!-- Access Notice textarea (PPT: renamed from "Login Popup") -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Style="{StaticResource InputLabel}"
                                   Text="Access Notice"
                                   Margin="0,0,0,6"
                                   ToolTip="Text shown when a session starts. PPT: renamed from Login Popup."/>
                        <TextBox Text="{Binding AccessNoticeText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}"
                                 Height="80"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 Padding="8,6"/>
                    </StackPanel>

                    <Separator Background="{DynamicResource HnVue.Semantic.Border.Default}" Margin="0,0,0,16"/>
                    <TextBlock Text="SYSTEM" Style="{StaticResource SettingsSectionLabel}"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Priority"/>
                        <ComboBox Grid.Column="1" Height="30" FontSize="12"
                                  FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                  Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                                  Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                                  BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}">
                            <ComboBoxItem Content="Normal" IsSelected="True"/>
                            <ComboBoxItem Content="High"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <!-- ─────── ACCOUNT tab ─────── -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Account}">

                    <TextBlock Text="NEW ACCOUNT" Style="{StaticResource SettingsSectionLabel}"/>

                    <!-- Account ID -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Account ID"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding NewAccountId, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}"/>
                    </Grid>

                    <!-- Role ComboBox — PPT: Operator field removed, role now a dropdown -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}"
                                   Text="Role"
                                   ToolTip="PPT: Operator field removed. Role is now a dropdown (Admin / Technician / Radiologist)."/>
                        <ComboBox Grid.Column="1"
                                  Height="30" FontSize="12"
                                  FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                  Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                                  Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                                  BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                                  ItemsSource="{Binding AvailableRoles}"
                                  SelectedItem="{Binding NewAccountRole}"/>
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="1"
                                Content="Add Account"
                                Style="{StaticResource HnVue.OutlineButton}"
                                Height="30" Padding="12,0" FontSize="11"
                                FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                    </Grid>

                    <Separator Background="{DynamicResource HnVue.Semantic.Border.Default}" Margin="0,0,0,16"/>
                    <TextBlock Text="ACCOUNT LIST" Style="{StaticResource SettingsSectionLabel}"/>

                    <Border MinHeight="160"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1">
                        <TextBlock Text="Account list will be populated here."
                                   Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                   FontSize="12" FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- ─────── DETECTOR tab ─────── -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Detector}">
                    <TextBlock Text="DETECTOR SETTINGS" Style="{StaticResource SettingsSectionLabel}"/>
                    <Border MinHeight="240"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1">
                        <TextBlock Text="Detector configuration (keep as-is per PPT)."
                                   Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                   FontSize="12" FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- ─────── GENERATOR tab ─────── -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Generator}">
                    <TextBlock Text="GENERATOR SETTINGS" Style="{StaticResource SettingsSectionLabel}"/>
                    <Border MinHeight="240"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1">
                        <TextBlock Text="Generator configuration (keep as-is per PPT)."
                                   Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                   FontSize="12" FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- ─────── NETWORK tab — PPT: PACS + Worklist + Print merged ─────── -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Network}">

                    <!-- PACS section -->
                    <TextBlock Text="PACS" Style="{StaticResource SettingsSectionLabel}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Server Address"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding PacsServerAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}" Margin="0,0,6,0"/>
                        <TextBox Grid.Column="2"
                                 Text="{Binding PacsServerPort, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}" Margin="0,0,6,0"
                                 ToolTip="Port"/>
                        <Button Grid.Column="3" Content="Add"
                                Style="{StaticResource HnVue.OutlineButton}"
                                Height="30" Padding="10,0" FontSize="11"
                                Margin="0,0,4,0"
                                FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                        <Button Grid.Column="4" Content="Edit"
                                Style="{StaticResource HnVue.OutlineButton}"
                                Height="30" Padding="10,0" FontSize="11"
                                FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                    </Grid>
                    <Border MinHeight="70" Margin="0,0,0,20"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1">
                        <TextBlock Text="PACS server list"
                                   Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                   FontSize="11" FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <Separator Background="{DynamicResource HnVue.Semantic.Border.Default}" Margin="0,0,0,16"/>

                    <!-- Worklist section -->
                    <TextBlock Text="WORKLIST" Style="{StaticResource SettingsSectionLabel}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Server Address"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding WorklistServerAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}" Margin="0,0,6,0"/>
                        <TextBox Grid.Column="2"
                                 Text="{Binding WorklistServerPort, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource SettingsTextBox}" Margin="0,0,6,0"
                                 ToolTip="Port"/>
                        <Button Grid.Column="3" Content="Add"
                                Style="{StaticResource HnVue.OutlineButton}"
                                Height="30" Padding="10,0" FontSize="11"
                                Margin="0,0,4,0"
                                FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                        <Button Grid.Column="4" Content="Edit"
                                Style="{StaticResource HnVue.OutlineButton}"
                                Height="30" Padding="10,0" FontSize="11"
                                FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                    </Grid>
                    <Border MinHeight="70" Margin="0,0,0,20"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1">
                        <TextBlock Text="Worklist server list"
                                   Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                   FontSize="11" FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <Separator Background="{DynamicResource HnVue.Semantic.Border.Default}" Margin="0,0,0,16"/>

                    <!-- Print section -->
                    <TextBlock Text="PRINT" Style="{StaticResource SettingsSectionLabel}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource InputLabel}" Text="Printer"/>
                        <ComboBox Grid.Column="1" Height="30" FontSize="12"
                                  FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                  Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                                  Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                                  BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}">
                            <ComboBoxItem Content="Default Printer" IsSelected="True"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <!-- ─────── DISPLAY tab ─────── -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Display}">
                    <TextBlock Text="DISPLAY SETTINGS" Style="{StaticResource SettingsSectionLabel}"/>
                    <Border MinHeight="200"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1">
                        <TextBlock Text="Display configuration placeholder."
                                   Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                   FontSize="12" FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- ─────── OPTION tab ─────── -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Option}">
                    <TextBlock Text="OPTIONS" Style="{StaticResource SettingsSectionLabel}"/>
                    <Border MinHeight="200"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1">
                        <TextBlock Text="Option configuration placeholder."
                                   Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                   FontSize="12" FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- ─────── DATABASE tab ─────── -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Database}">
                    <TextBlock Text="DATABASE SETTINGS" Style="{StaticResource SettingsSectionLabel}"/>
                    <Border MinHeight="200"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1">
                        <TextBlock Text="Database configuration placeholder."
                                   Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                   FontSize="12" FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- ─────── DICOMSET tab ─────── -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=DicomSet}">
                    <TextBlock Text="DICOM SETTINGS" Style="{StaticResource SettingsSectionLabel}"/>
                    <Border MinHeight="200"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1">
                        <TextBlock Text="DICOM set configuration placeholder."
                                   Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                   FontSize="12" FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- ─────── RIS CODE tab ─────── -->
                <!-- PPT: "Only No matching" renamed to "Un-Matched" -->
                <StackPanel Visibility="{Binding ActiveTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=RIS Code}">

                    <!-- RIS Code sub-tab row -->
                    <Border Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="0,0,0,1"
                            Margin="0,0,0,16"
                            Padding="0,2,0,0">
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton Content="Matching"
                                          Style="{StaticResource RisSubTabButton}"
                                          IsChecked="{Binding ActiveRisTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Matching, Mode=OneWay}"
                                          Command="{Binding SelectTabCommand}"
                                          CommandParameter="Matching"/>
                            <!-- PPT: "Only No matching" → "Un-Matched" -->
                            <ToggleButton Content="Un-Matched"
                                          Style="{StaticResource RisSubTabButton}"
                                          IsChecked="{Binding ActiveRisTab, Converter={StaticResource StringEqualityToBool}, ConverterParameter=Un-Matched, Mode=OneWay}"
                                          Command="{Binding SelectTabCommand}"
                                          CommandParameter="Un-Matched"/>
                        </StackPanel>
                    </Border>

                    <!-- Matching sub-tab content -->
                    <Border Visibility="{Binding ActiveRisTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Matching}"
                            MinHeight="200"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1">
                        <TextBlock Text="Matching RIS code list and mapping configuration."
                                   Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                   FontSize="12" FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Un-Matched sub-tab content (PPT: formerly "Only No matching") -->
                    <Border Visibility="{Binding ActiveRisTab, Converter={StaticResource ActiveTabToVisibility}, ConverterParameter=Un-Matched}"
                            MinHeight="200"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1">
                        <TextBlock Text="Un-Matched RIS codes (formerly: Only No matching)."
                                   Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                   FontSize="12" FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

            </Grid>
        </ScrollViewer>

        <!-- ═══════════════════ Action Bar ═══════════════════ -->
        <Border Grid.Row="3"
                Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Error message -->
                <TextBlock Grid.Column="0"
                           Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource HnVue.Semantic.Status.Emergency}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                <Button Grid.Column="1"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource HnVue.OutlineButton}"
                        Width="100" Height="36"
                        Margin="0,0,8,0"
                        FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>

                <Button Grid.Column="2"
                        Content="Save"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource HnVue.PrimaryButton}"
                        Width="100" Height="36"
                        FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
