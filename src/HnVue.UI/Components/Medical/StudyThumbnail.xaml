<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:HnVue.UI.Components.Medical">

    <!-- ═══════════════════════════════════════════════════════════
         Study Thumbnail Component
         Displays thumbnail preview of medical images/studies
         ═══════════════════════════════════════════════════════════ -->

    <Style TargetType="local:StudyThumbnail">
        <Setter Property="Background" Value="{StaticResource DS2026.Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource DS2026.Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Width" Value="200" />
        <Setter Property="Height" Value="200" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:StudyThumbnail">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource DS2026.CornerRadius.LG}"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Cursor="{TemplateBinding Cursor}">
                        <Grid>
                            <!-- Thumbnail Image -->
                            <Image Source="{TemplateBinding ThumbnailSource}"
                                   Stretch="Uniform"
                                   Margin="{TemplateBinding Padding}"
                                   x:Name="ThumbnailImage" />

                            <!-- Placeholder (when no image) -->
                            <Border x:Name="Placeholder"
                                    Background="#1A1A2E"
                                    Visibility="Collapsed">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="M21,19V5C21,3.89 20.1,3 19,3H5C3.89,3 3,3.89 3,5V19C3,20.1 3.89,21 5,21H19C20.1,21 21,20.1 21,19M8.5,13.5L11,16.51L14.5,12L19,18H5L8.5,13.5Z"
                                          Fill="{StaticResource DS2026.Brush.TextMuted}"
                                          Opacity="0.5"
                                          Width="48"
                                          Height="48"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center" />
                                    <TextBlock Text="{TemplateBinding PlaceholderText}"
                                               Foreground="{StaticResource DS2026.Brush.TextMuted}"
                                               FontSize="{StaticResource DS2026.FontSize.Caption}"
                                               TextAlignment="Center"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <!-- Overlay on Selection -->
                            <Border x:Name="SelectionOverlay"
                                    BorderThickness="3"
                                    BorderBrush="{StaticResource DS2026.Brush.Primary}"
                                    CornerRadius="{StaticResource DS2026.CornerRadius.LG}"
                                    Visibility="Collapsed" />

                            <!-- Info Footer -->
                            <Border VerticalAlignment="Bottom"
                                    Background="#E0000000"
                                    CornerRadius="0,0,12,12"
                                    Padding="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{TemplateBinding SeriesDescription}"
                                               Foreground="{StaticResource DS2026.Brush.Text}"
                                               FontSize="{StaticResource DS2026.FontSize.Caption}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="140" />

                                    <TextBlock Grid.Column="1"
                                               Text="{TemplateBinding ImageCount}"
                                               Foreground="{StaticResource DS2026.Brush.TextMuted}"
                                               FontSize="{StaticResource DS2026.FontSize.Caption}"
                                               Margin="8,0,0,0" />
                                </Grid>
                            </Border>

                            <!-- Status Indicator -->
                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="{Binding StatusBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                    CornerRadius="{StaticResource DS2026.CornerRadius.SM}"
                                    Width="12"
                                    Height="12"
                                    Margin="8" />
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Show placeholder when no image source -->
                        <Trigger Property="ThumbnailSource" Value="{x:Null}">
                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ThumbnailImage" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!-- Show selection overlay when selected -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="SelectionOverlay" Property="Visibility" Value="Visible" />
                            <Setter Property="BorderBrush" Value="{StaticResource DS2026.Brush.Primary}" />
                            <Setter Property="BorderThickness" Value="2" />
                        </Trigger>

                        <!-- Hover effect -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource DS2026.Brush.Primary.Light}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
