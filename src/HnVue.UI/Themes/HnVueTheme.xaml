<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:System="clr-namespace:System;assembly=mscorlib">

    <!-- HnVue Color Palette -->
    <Color x:Key="HnVue.Primary.Color">#1B4F8A</Color>
    <Color x:Key="HnVue.Primary.Light.Color">#2E6DB4</Color>
    <Color x:Key="HnVue.Accent.Color">#00AEEF</Color>
    <Color x:Key="HnVue.Background.Dark.Color">#1A1A2E</Color>
    <Color x:Key="HnVue.Background.Panel.Color">#16213E</Color>
    <Color x:Key="HnVue.Background.Card.Color">#0F3460</Color>
    <Color x:Key="HnVue.Text.Primary.Color">#FFFFFF</Color>
    <Color x:Key="HnVue.Text.Secondary.Color">#B0BEC5</Color>
    <Color x:Key="HnVue.Success.Color">#4CAF50</Color>
    <Color x:Key="HnVue.Warning.Color">#FF9800</Color>
    <Color x:Key="HnVue.Error.Color">#F44336</Color>

    <SolidColorBrush x:Key="HnVue.Primary.Brush" Color="{StaticResource HnVue.Primary.Color}" />
    <SolidColorBrush x:Key="HnVue.Accent.Brush" Color="{StaticResource HnVue.Accent.Color}" />
    <SolidColorBrush x:Key="HnVue.Background.Dark.Brush" Color="{StaticResource HnVue.Background.Dark.Color}" />
    <SolidColorBrush x:Key="HnVue.Background.Panel.Brush" Color="{StaticResource HnVue.Background.Panel.Color}" />
    <SolidColorBrush x:Key="HnVue.Background.Card.Brush" Color="{StaticResource HnVue.Background.Card.Color}" />
    <SolidColorBrush x:Key="HnVue.Text.Primary.Brush" Color="{StaticResource HnVue.Text.Primary.Color}" />
    <SolidColorBrush x:Key="HnVue.Text.Secondary.Brush" Color="{StaticResource HnVue.Text.Secondary.Color}" />
    <SolidColorBrush x:Key="HnVue.Success.Brush" Color="{StaticResource HnVue.Success.Color}" />
    <SolidColorBrush x:Key="HnVue.Error.Brush" Color="{StaticResource HnVue.Error.Color}" />

    <!-- Typography -->
    <FontFamily x:Key="HnVue.FontFamily">Segoe UI</FontFamily>
    <System:Double x:Key="HnVue.FontSize.Small">11</System:Double>
    <System:Double x:Key="HnVue.FontSize.Normal">13</System:Double>
    <System:Double x:Key="HnVue.FontSize.Large">16</System:Double>
    <System:Double x:Key="HnVue.FontSize.Header">20</System:Double>

    <!-- Spacing -->
    <Thickness x:Key="HnVue.Spacing.Small">4</Thickness>
    <Thickness x:Key="HnVue.Spacing.Normal">8</Thickness>
    <Thickness x:Key="HnVue.Spacing.Large">16</Thickness>

    <!-- Button Styles -->
    <Style x:Key="HnVue.PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource HnVue.Primary.Brush}" />
        <Setter Property="Foreground" Value="{StaticResource HnVue.Text.Primary.Brush}" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontSize" Value="{StaticResource HnVue.FontSize.Normal}" />
        <Setter Property="FontFamily" Value="{StaticResource HnVue.FontFamily}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="HnVue.SecondaryButton" TargetType="Button" BasedOn="{StaticResource HnVue.PrimaryButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource HnVue.Accent.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

</ResourceDictionary>
