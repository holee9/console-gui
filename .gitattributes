# Git Attributes — HnVue Console GUI
# UTF-8 인코딩 표준화 + 한글 파일명 정합성 보장

# 기본: 자동 줄바꿈 정규화
* text=auto

# C# / WPF 소스 파일
*.cs    text eol=crlf encoding=utf-8
*.xaml  text eol=crlf encoding=utf-8
*.xml   text eol=crlf encoding=utf-8
*.csproj text eol=crlf encoding=utf-8
*.sln   text eol=crlf encoding=utf-8
*.props text eol=crlf encoding=utf-8
*.targets text eol=crlf encoding=utf-8

# 문서 및 스크립트
*.md    text eol=lf encoding=utf-8
*.yaml  text eol=lf encoding=utf-8
*.yml   text eol=lf encoding=utf-8
*.json  text eol=lf encoding=utf-8
*.ps1   text eol=crlf encoding=utf-8

# 바이너리 파일 (줄바꿈 변환 제외)
*.pptx  binary
*.docx  binary
*.pdf   binary
*.png   binary
*.jpg   binary
*.ico   binary
*.dll   binary
*.exe   binary
*.db    binary
