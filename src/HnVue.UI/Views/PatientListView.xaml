<UserControl x:Class="HnVue.UI.Views.PatientListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:HnVue.UI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1400">
    <UserControl.Resources>
        <converters:AgeFromBirthDateConverter x:Key="AgeConverter"/>
        <!-- PPT Slide 5/6: ListBoxItem height 44px for accessibility (WCAG 2.5.5) -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Height" Value="44"/>
        </Style>
        <Style x:Key="DarkHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Surface.Panel}"/>
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Text.Secondary}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
        </Style>
        <Style x:Key="DarkRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Surface.Page}"/>
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Component.DataGrid.GridLine}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Surface.Card}"/>
                    <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource HnVue.Component.DataGrid.SelectionBg}"/>
                    <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Brand.PrimaryLight}"/>
                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- PPT Slide 4: Loading state indicator -->
        <Style x:Key="LoadingTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Secondary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SideIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Surface.Panel}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Border.Default}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="17"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource HnVue.Semantic.Surface.Page}" Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="260"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Column="0" Grid.Row="0" Margin="0,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- PPT Slide 6: Section badge "Worklist" with SectionBadge.Bg background -->
            <Border Grid.Column="0"
                    Background="{DynamicResource HnVue.Component.SectionBadge.Bg}"
                    CornerRadius="3"
                    Padding="8,2"
                    VerticalAlignment="Center"
                    Margin="0,0,10,0">
                <TextBlock Text="Worklist"
                           Style="{StaticResource HnVue.SectionBadgeText}"/>
            </Border>
            <!-- PPT Slide 6: Emergency badge using Status.Emergency color -->
            <Border Grid.Column="1"
                    Background="{DynamicResource HnVue.Semantic.Status.Emergency}"
                    CornerRadius="3"
                    Padding="6,2"
                    VerticalAlignment="Center"
                    Margin="0,0,10,0"
                    Visibility="Collapsed">
                <TextBlock Text="EMRG"
                           Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                           FontSize="10"
                           FontWeight="Bold"/>
            </Border>
            <TextBlock Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" FontSize="26" VerticalAlignment="Center"/>
            <!-- PPT Slide 5: Period filter buttons with OutlineButton style -->
            <StackPanel Grid.Column="4" Orientation="Horizontal">
                <Button Content="Today" Style="{StaticResource HnVue.OutlineButton}" Command="{Binding FilterByPeriodCommand}" CommandParameter="Today" Width="82" Height="32" Margin="0,0,6,0" AutomationProperties.Name="오늘 환자 목록"/>
                <Button Content="3Days" Style="{StaticResource HnVue.OutlineButton}" Command="{Binding FilterByPeriodCommand}" CommandParameter="3Days" Width="82" Height="32" Margin="0,0,6,0" AutomationProperties.Name="최근 3일 환자 목록"/>
                <Button Content="1Week" Style="{StaticResource HnVue.OutlineButton}" Command="{Binding FilterByPeriodCommand}" CommandParameter="1Week" Width="82" Height="32" Margin="0,0,6,0" AutomationProperties.Name="최근 1주 환자 목록"/>
                <Button Content="All" Style="{StaticResource HnVue.OutlineButton}" Command="{Binding FilterByPeriodCommand}" CommandParameter="All" Width="70" Height="32" Margin="0,0,6,0" AutomationProperties.Name="전체 환자 목록"/>
                <Button Content="1Month" Style="{StaticResource HnVue.OutlineButton}" Command="{Binding FilterByPeriodCommand}" CommandParameter="1Month" Width="90" Height="32" AutomationProperties.Name="최근 1개월 환자 목록"/>
            </StackPanel>
            <DatePicker Grid.Column="5" Width="130" Height="32" Margin="12,0,6,0" AutomationProperties.Name="날짜 선택"/>
            <DatePicker Grid.Column="6" Width="130" Height="32"/>
        </Grid>

        <Grid Grid.Column="0" Grid.Row="1" Margin="0,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource HnVue.Semantic.Surface.Page}" BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}" BorderThickness="1">
                <Grid>
                    <DataGrid ItemsSource="{Binding Patients}"
                              SelectedItem="{Binding SelectedPatient}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource HnVue.Component.DataGrid.GridLine}"
                              BorderThickness="0"
                              RowHeaderWidth="0"
                              Background="{DynamicResource HnVue.Semantic.Surface.Page}"
                              Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                              ColumnHeaderHeight="34"
                              RowHeight="40"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling">
                        <DataGrid.ColumnHeaderStyle>
                            <StaticResource ResourceKey="DarkHeaderStyle"/>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <StaticResource ResourceKey="DarkRowStyle"/>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="No" Binding="{Binding PatientId}" Width="70"/>
                            <DataGridTextColumn Header="Patient ID" Binding="{Binding PatientId}" Width="210"/>
                            <DataGridTextColumn Header="Patient Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Sex" Binding="{Binding Sex}" Width="60"/>
                            <DataGridTextColumn Header="Age" Binding="{Binding DateOfBirth, Converter={StaticResource AgeConverter}}" Width="80"/>
                            <DataGridTextColumn Header="BirthDate" Binding="{Binding DateOfBirth, StringFormat={}{0:yyyyMMdd}}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <!-- PPT Slide 4: Empty state with improved message -->
                    <Border Margin="0,34,0,0" Background="{DynamicResource HnVue.Semantic.Surface.Page}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Patients.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <!-- PPT Slide 4: Empty state message -->
                        <Grid Margin="0,40,0,0">
                            <TextBlock Text="No patients found" Style="{StaticResource LoadingTextStyle}"/>
                        </Grid>
                    </Border>
                    <!-- PPT Slide 4: Loading state placeholder -->
                    <Border Margin="0,34,0,0" Background="{DynamicResource HnVue.Semantic.Surface.Page}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid Margin="0,6,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="210"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Row="0" Grid.ColumnSpan="6" Background="{DynamicResource HnVue.Semantic.Surface.Card}"/>
                            <Border Grid.Row="1" Grid.ColumnSpan="6" Background="{DynamicResource HnVue.Semantic.Surface.Page}"/>
                            <Border Grid.Row="2" Grid.ColumnSpan="6" Background="{DynamicResource HnVue.Semantic.Surface.Card}"/>
                            <Border Grid.Row="3" Grid.ColumnSpan="6" Background="{DynamicResource HnVue.Semantic.Surface.Page}"/>
                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="1"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="PT-20251013-001"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="Sample Patient"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="M"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="38"/>
                            <TextBlock Grid.Row="0" Grid.Column="5" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="19880101"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="2"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="PT-20251012-018"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="Minji Park"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="F"/>
                            <TextBlock Grid.Row="1" Grid.Column="4" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="42"/>
                            <TextBlock Grid.Row="1" Grid.Column="5" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="19840211"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="3"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="PT-20251012-009"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="Jisoo Kim"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="F"/>
                            <TextBlock Grid.Row="2" Grid.Column="4" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="29"/>
                            <TextBlock Grid.Row="2" Grid.Column="5" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="19961030"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="4"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="PT-20251011-004"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="Daniel Lee"/>
                            <TextBlock Grid.Row="3" Grid.Column="3" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="M"/>
                            <TextBlock Grid.Row="3" Grid.Column="4" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="55"/>
                            <TextBlock Grid.Row="3" Grid.Column="5" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="19710204"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource HnVue.Semantic.Surface.Page}" BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}" BorderThickness="1">
                <Grid>
                    <DataGrid ItemsSource="{Binding Patients}"
                              SelectedItem="{Binding SelectedPatient}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource HnVue.Component.DataGrid.GridLine}"
                              BorderThickness="0"
                              RowHeaderWidth="0"
                              Background="{DynamicResource HnVue.Semantic.Surface.Page}"
                              Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                              ColumnHeaderHeight="34"
                              RowHeight="40"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling">
                        <DataGrid.ColumnHeaderStyle>
                            <StaticResource ResourceKey="DarkHeaderStyle"/>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <StaticResource ResourceKey="DarkRowStyle"/>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Accession No" Binding="{Binding PatientId}" Width="210"/>
                            <DataGridTextColumn Header="StudyDate" Binding="{Binding CreatedAt, StringFormat={}{0:yyyyMMdd}}" Width="140"/>
                            <DataGridTextColumn Header="StudyDescription" Binding="{Binding Name}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <!-- PPT Slide 4: Empty state for study list -->
                    <Border Margin="0,34,0,0" Background="{DynamicResource HnVue.Semantic.Surface.Page}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Patients.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <!-- PPT Slide 4: Empty state message for study list -->
                        <Grid Margin="0,40,0,0">
                            <TextBlock Text="No studies found" Style="{StaticResource LoadingTextStyle}"/>
                        </Grid>
                    </Border>
                    <!-- PPT Slide 4: Loading state placeholder for study list -->
                    <Border Margin="0,34,0,0" Background="{DynamicResource HnVue.Semantic.Surface.Page}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid Margin="0,6,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="210"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Row="0" Grid.ColumnSpan="3" Background="{DynamicResource HnVue.Semantic.Surface.Card}"/>
                            <Border Grid.Row="1" Grid.ColumnSpan="3" Background="{DynamicResource HnVue.Semantic.Surface.Page}"/>
                            <Border Grid.Row="2" Grid.ColumnSpan="3" Background="{DynamicResource HnVue.Semantic.Surface.Card}"/>
                            <Border Grid.Row="3" Grid.ColumnSpan="3" Background="{DynamicResource HnVue.Semantic.Surface.Page}"/>
                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="ACC-24101301"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="20251013"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="CHEST PA"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="ACC-24101218"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="20251012"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="L-SPINE AP/LAT"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="ACC-24101209"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="20251012"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Text="KNEE BOTH AP/LAT"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="ACC-24101104"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="20251011"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Margin="12,11,0,0" Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}" Text="ABDOMEN SUPINE"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Column="0" Grid.Row="2" Text="{Binding Patients.Count, StringFormat=Total: {0}}" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Margin="8,8,0,0"/>

        <Border Grid.Column="1" Grid.RowSpan="3" Background="{DynamicResource HnVue.Semantic.Surface.Panel}" BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}" BorderThickness="1" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" Height="32">
                        <ComboBoxItem Content="ALL" IsSelected="True"/>
                    </ComboBox>
                    <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Margin="6,0,6,0" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="2" Content="&#xE721;" Style="{StaticResource SideIconButtonStyle}" Width="32" Height="32" Margin="0"/>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox Content="Suspend" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}" Margin="0,0,10,0"/>
                    <CheckBox Content="Hide" Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"/>
                </StackPanel>

                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <DatePicker Grid.Column="0" Height="30"/>
                    <DatePicker Grid.Column="2" Height="30"/>
                </Grid>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="&#xECA5;" Style="{StaticResource SideIconButtonStyle}"/>
                    <Button Content="&#xE14C;" Style="{StaticResource SideIconButtonStyle}"/>
                </StackPanel>

                <Button Grid.Row="4"
                        Content="Quick Start"
                        Command="{Binding SelectPatientCommand}"
                        CommandParameter="{Binding SelectedPatient}"
                        Background="{DynamicResource HnVue.Semantic.Status.Emergency}"
                        BorderBrush="{DynamicResource HnVue.Semantic.Status.Emergency}"
                        Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                        FontWeight="Bold"
                        Height="46"
                        VerticalAlignment="Top"/>

                <WrapPanel Grid.Row="5" Margin="0,12,0,0">
                    <Button Content="&#xE710;" Style="{StaticResource SideIconButtonStyle}"/>
                    <Button Content="&#xE70F;" Style="{StaticResource SideIconButtonStyle}"/>
                    <Button Content="&#xE74D;" Style="{StaticResource SideIconButtonStyle}"/>
                    <Button Content="&#xE72F;" Style="{StaticResource SideIconButtonStyle}"/>
                    <Button Content="&#xE721;" Style="{StaticResource SideIconButtonStyle}"/>
                </WrapPanel>

                <WrapPanel Grid.Row="6" Margin="0,8,0,0">
                    <Button Content="&#xE7B5;" Style="{StaticResource SideIconButtonStyle}"/>
                    <Button Content="&#xE898;" Style="{StaticResource SideIconButtonStyle}"/>
                    <Button Content="&#xE749;" Style="{StaticResource SideIconButtonStyle}"/>
                    <Button Content="&#xE958;" Style="{StaticResource SideIconButtonStyle}"/>
                    <Button Content="&#xE1D8;" Style="{StaticResource SideIconButtonStyle}"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
