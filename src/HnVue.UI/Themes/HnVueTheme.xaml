<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:System="clr-namespace:System;assembly=mscorlib">

    <!--
        @MX:NOTE Theme merge order is critical: DarkTheme MUST load before CoreTokens.
                 CoreTokens provides raw Color primitives; DarkTheme overrides them.
                 SemanticTokens and ComponentTokens consume via DynamicResource so they
                 always reflect the active theme without recompilation.
                 Do NOT reorder the MergedDictionaries entries below.
    -->
    <!-- ═══════════════════════════════════════════════════════════
         HnVue Design Token Entry Point

         Load order:
           1. DarkTheme  — overrides Core color values (default: dark)
           2. CoreTokens — raw primitives (typography, spacing, corners)
           3. SemanticTokens — meaningful Brush aliases → Core
           4. ComponentTokens — per-component Brush aliases → Semantic

         To switch themes, swap DarkTheme for LightTheme or HighContrastTheme
         before loading CoreTokens. All downstream resources use DynamicResource
         so live switching is supported.
         ═══════════════════════════════════════════════════════════ -->

    <ResourceDictionary.MergedDictionaries>
        <!-- Active theme: swap this entry to switch themes -->
        <ResourceDictionary Source="dark/DarkTheme.xaml" />

        <!-- Token layers -->
        <ResourceDictionary Source="tokens/CoreTokens.xaml" />
        <ResourceDictionary Source="tokens/SemanticTokens.xaml" />
        <ResourceDictionary Source="tokens/ComponentTokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- ═══════════════════════════════════════════════════════════
         BACKWARD COMPATIBILITY ALIASES

         These keys preserve the original HnVueTheme.xaml API so that
         MainWindow.xaml, App.xaml, and all View XAML files continue to
         work without modification.

         All aliases use DynamicResource to remain theme-switch-aware.
         DO NOT remove these entries while legacy XAML files reference them.
         ═══════════════════════════════════════════════════════════ -->

    <!-- ── Color aliases (original Color resources) ── -->
    <Color x:Key="HnVue.Primary.Color">#1B4F8A</Color>
    <Color x:Key="HnVue.Primary.Light.Color">#2E6DB4</Color>
    <Color x:Key="HnVue.Accent.Color">#00AEEF</Color>
    <Color x:Key="HnVue.Background.Dark.Color">#0d1527</Color>
    <Color x:Key="HnVue.Background.Panel.Color">#1a2540</Color>
    <Color x:Key="HnVue.Background.Card.Color">#1e2d4a</Color>
    <Color x:Key="HnVue.Text.Primary.Color">#FFFFFF</Color>
    <Color x:Key="HnVue.Text.Secondary.Color">#B0BEC5</Color>
    <!-- IEC 62366 safety-critical status colors — must match CoreTokens exactly -->
    <Color x:Key="HnVue.Success.Color">#00C853</Color>
    <Color x:Key="HnVue.Warning.Color">#FFD600</Color>
    <Color x:Key="HnVue.Blocked.Color">#FF6D00</Color>
    <Color x:Key="HnVue.Error.Color">#D50000</Color>

    <!-- ── Brush aliases (original SolidColorBrush resources) ── -->
    <SolidColorBrush x:Key="HnVue.Primary.Brush"
                     Color="{DynamicResource HnVue.Core.Color.Primary}" />
    <SolidColorBrush x:Key="HnVue.Accent.Brush"
                     Color="{DynamicResource HnVue.Core.Color.Accent}" />
    <SolidColorBrush x:Key="HnVue.Background.Dark.Brush"
                     Color="{DynamicResource HnVue.Core.Color.BackgroundPage}" />
    <SolidColorBrush x:Key="HnVue.Background.Panel.Brush"
                     Color="{DynamicResource HnVue.Core.Color.BackgroundPanel}" />
    <SolidColorBrush x:Key="HnVue.Background.Card.Brush"
                     Color="{DynamicResource HnVue.Core.Color.BackgroundCard}" />
    <SolidColorBrush x:Key="HnVue.Text.Primary.Brush"
                     Color="{DynamicResource HnVue.Core.Color.TextPrimary}" />
    <SolidColorBrush x:Key="HnVue.Text.Secondary.Brush"
                     Color="{DynamicResource HnVue.Core.Color.TextSecondary}" />
    <SolidColorBrush x:Key="HnVue.Success.Brush"
                     Color="{DynamicResource HnVue.Core.Color.StatusSafe}" />
    <SolidColorBrush x:Key="HnVue.Warning.Brush"
                     Color="{DynamicResource HnVue.Core.Color.StatusWarning}" />
    <SolidColorBrush x:Key="HnVue.Blocked.Brush"
                     Color="{DynamicResource HnVue.Core.Color.StatusBlocked}" />
    <SolidColorBrush x:Key="HnVue.Error.Brush"
                     Color="{DynamicResource HnVue.Core.Color.StatusEmergency}" />

    <!-- ── Typography aliases ── -->
    <FontFamily x:Key="HnVue.FontFamily">Segoe UI</FontFamily>
    <System:Double x:Key="HnVue.FontSize.Small">11</System:Double>
    <System:Double x:Key="HnVue.FontSize.Normal">13</System:Double>
    <System:Double x:Key="HnVue.FontSize.Large">16</System:Double>
    <System:Double x:Key="HnVue.FontSize.Header">20</System:Double>

    <!-- ── Spacing aliases ── -->
    <Thickness x:Key="HnVue.Spacing.Small">4</Thickness>
    <Thickness x:Key="HnVue.Spacing.Normal">8</Thickness>
    <Thickness x:Key="HnVue.Spacing.Large">16</Thickness>

    <!-- ═══════════════════════════════════════════════════════════
         BUTTON STYLES
         Kept here (not in ComponentTokens) to remain in a single
         ResourceDictionary alongside the backward-compatible color keys
         they depend on.
         ═══════════════════════════════════════════════════════════ -->

    <Style x:Key="HnVue.PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Button.Primary}" />
        <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="FontSize" Value="{DynamicResource HnVue.Core.FontSize.Normal}" />
        <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource HnVue.Semantic.Button.PrimaryHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource HnVue.Semantic.Brand.Primary}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Emergency Stop button style — IEC 62366 safety-critical, always 56px, #D50000 -->
    <Style x:Key="HnVue.EmergencyStopButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Status.Emergency}" />
        <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.OnEmergency}" />
        <Setter Property="MinHeight" Value="56" />
        <Setter Property="MinWidth" Value="100" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontSize" Value="{DynamicResource HnVue.Core.FontSize.Large}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="AutomationProperties.Name" Value="Emergency Stop" />
        <Setter Property="AutomationProperties.HelpText" Value="Immediately stops radiation exposure. Keyboard: Escape" />
        <!-- Never disable this button — IEC 62366 requires it always be operable -->
        <Setter Property="IsEnabled" Value="True" />
    </Style>

    <!-- Danger button — for high-risk actions (delete, override) -->
    <Style x:Key="HnVue.DangerButton" TargetType="Button" BasedOn="{StaticResource HnVue.PrimaryButton}">
        <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Button.Danger}" />
    </Style>

    <Style x:Key="HnVue.SecondaryButton" TargetType="Button" BasedOn="{StaticResource HnVue.PrimaryButton}">
        <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Button.Secondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Brand.Accent}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!--
        White outline button — matches current UI screenshot style exactly.
        Used by: ImageViewerView (ZOOM IN/OUT/RESET W/L), toolbar actions.
        @MX:NOTE This preserves the existing white-border-on-dark look from the current app.
    -->
    <Style x:Key="HnVue.OutlineButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Text.Primary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,5" />
        <Setter Property="Height" Value="32" />
        <Setter Property="FontSize" Value="{DynamicResource HnVue.Core.FontSize.Small}" />
        <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource HnVue.Semantic.Border.Default}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource HnVue.Semantic.Brand.Primary}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Accent outline button — for focused/active toolbar items -->
    <Style x:Key="HnVue.AccentOutlineButton" TargetType="Button"
           BasedOn="{StaticResource HnVue.OutlineButton}">
        <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Brand.Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Brand.Accent}" />
    </Style>

    <!-- Compact text input style for dark theme -->
    <Style x:Key="HnVue.DarkTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Surface.Card}" />
        <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Border.Default}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Height" Value="36" />
        <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource HnVue.Core.FontSize.Normal}" />
        <Setter Property="CaretBrush" Value="{DynamicResource HnVue.Semantic.Brand.Accent}" />
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Border.Focus}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Section header text style -->
    <Style x:Key="HnVue.SectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource HnVue.Core.FontSize.Large}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}" />
        <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}" />
    </Style>

    <!-- Muted label text style -->
    <Style x:Key="HnVue.MutedLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource HnVue.Core.FontSize.Small}" />
        <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Secondary}" />
        <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}" />
    </Style>

    <!--
        Section badge text style — PPT Slide 3 & 6 spec.
        Usage: TextBlock inside a Border with HnVue.SectionBadge.Bg background.
        Spec: 12px/700/#f9e04b, bg:#2a3a5c, pad:2px 8px, radius:3px
    -->
    <Style x:Key="HnVue.SectionBadgeText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource HnVue.Component.SectionBadge.Text}" />
        <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!--
        Detail panel header text style — PPT Slide 6 spec.
        Usage: "상세" panel title. Spec: 11px/700/#7bc8f5
    -->
    <Style x:Key="HnVue.DetailHeaderText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource HnVue.Component.SectionBadge.DetailText}" />
        <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!--
        Uppercase label style — PPT Slide 3 spec.
        Usage: field labels in login form. Spec: 10px/600/#7090b0, uppercase
    -->
    <Style x:Key="HnVue.UppercaseLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource HnVue.Component.Label.Muted}" />
        <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
    </Style>

    <!-- Cancel button style — secondary action, transparent bg with border -->
    <Style x:Key="HnVue.CancelButton" TargetType="Button" BasedOn="{StaticResource HnVue.OutlineButton}">
        <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Border.Default}" />
        <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Secondary}" />
        <Setter Property="Height" Value="44" />
    </Style>

    <!-- ═══ Login Styles (PPT Slide 2/3 spec) ═══
         InputBgLogin=#ffffff, InputFgLogin=#1c2333, InputBorderDefault=#cccccc, InputBorderFocus=#1a6fc7
         BtnIconColor=#ffffff, BtnHoverBg=#33ffffff (20% white), BtnPressedBg=#55ffffff (33% white)
    -->
    <Style x:Key="HnVue.Login.TextBoxStyle" TargetType="TextBox">
        <Setter Property="Background"                   Value="White"/>
        <Setter Property="Foreground"                   Value="#1c2333"/>
        <Setter Property="BorderBrush"                  Value="#cccccc"/>
        <Setter Property="BorderThickness"              Value="1"/>
        <Setter Property="Padding"                      Value="8,0"/>
        <Setter Property="FontFamily"                   Value="Malgun Gothic"/>
        <Setter Property="FontSize"                     Value="13"/>
        <Setter Property="VerticalContentAlignment"     Value="Center"/>
        <Setter Property="CaretBrush"                   Value="#1c2333"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush"          Value="#1a6fc7"/>
                <Setter Property="BorderThickness"      Value="2"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="HnVue.Login.PasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="Background"                   Value="White"/>
        <Setter Property="Foreground"                   Value="#1c2333"/>
        <Setter Property="BorderBrush"                  Value="#cccccc"/>
        <Setter Property="BorderThickness"              Value="1"/>
        <Setter Property="Padding"                      Value="8,0"/>
        <Setter Property="FontFamily"                   Value="Malgun Gothic"/>
        <Setter Property="FontSize"                     Value="13"/>
        <Setter Property="VerticalContentAlignment"     Value="Center"/>
        <Setter Property="CaretBrush"                   Value="#1c2333"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush"          Value="#1a6fc7"/>
                <Setter Property="BorderThickness"      Value="2"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="HnVue.Login.IconButtonStyle" TargetType="Button">
        <Setter Property="Background"                   Value="Transparent"/>
        <Setter Property="BorderThickness"              Value="0"/>
        <Setter Property="Cursor"                       Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" Padding="8"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#33ffffff"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#55ffffff"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
