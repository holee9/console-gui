<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Primary Colors -->
    <SolidColorBrush x:Key="Primary.Main" Color="#FF0066CC"/>
    <SolidColorBrush x:Key="Primary.Light" Color="#FF4D94FF"/>
    <SolidColorBrush x:Key="Primary.Dark" Color="#FF004080"/>

    <!-- Secondary Colors -->
    <SolidColorBrush x:Key="Secondary.Teal" Color="#FF00BFA5"/>
    <SolidColorBrush x:Key="Secondary.Coral" Color="#FFFF6B6B"/>
    <SolidColorBrush x:Key="Secondary.Amber" Color="#FFFFC107"/>

    <!-- Neutral Colors (Dark Mode) -->
    <SolidColorBrush x:Key="Neutral.Background" Color="#FF1A1A2E"/>
    <SolidColorBrush x:Key="Neutral.Surface" Color="#FF252542"/>
    <SolidColorBrush x:Key="Neutral.Border" Color="#FF3E3E5E"/>
    <SolidColorBrush x:Key="Neutral.Text" Color="#FFE0E0E0"/>
    <SolidColorBrush x:Key="Neutral.TextMuted" Color="#FFA0A0B0"/>

    <!-- Semantic Colors -->
    <SolidColorBrush x:Key="Semantic.Error" Color="#FFFF4757"/>
    <SolidColorBrush x:Key="Semantic.Warning" Color="#FFFFA502"/>
    <SolidColorBrush x:Key="Semantic.Success" Color="#FF2ED573"/>
    <SolidColorBrush x:Key="Semantic.Info" Color="#FF1E90FF"/>

    <!-- State Colors -->
    <SolidColorBrush x:Key="State.Hover" Color="#4DFFFFFF"/>
    <SolidColorBrush x:Key="State.Pressed" Color="#80000000"/>
    <SolidColorBrush x:Key="State.Focus" Color="#FF4D94FF"/>
    <SolidColorBrush x:Key="State.Disabled" Color="#4DFFFFFF"/>

</ResourceDictionary>
