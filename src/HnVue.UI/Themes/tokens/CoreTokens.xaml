<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!--
        @MX:ANCHOR CoreTokens — Single source of truth for ALL design tokens.
        @MX:NOTE   All color values are IEC 62366 safety-color compliant.
                   Never change values here without updating:
                   1. docs/ui_mockups/design_system.pen (Pencil design file)
                   2. docs/ui_mockups/PENCIL_DESIGN_SUMMARY.md
                   3. docs/usability/METRICS_HISTORY.md (baseline reference)
                   SemanticTokens.xaml, ComponentTokens.xaml, HnVueTheme.xaml
                   all use DynamicResource and will pick up changes automatically.
    -->

    <!-- ═══════════════════════════════════════════════════════════
         Level 1: Core Design Tokens
         Raw design primitives — theme files override these values.
         All Color resources (no Brushes at this level).
         ═══════════════════════════════════════════════════════════ -->

    <!-- ═══ Brand Colors ═══ -->
    <Color x:Key="HnVue.Core.Color.Primary">#1B4F8A</Color>
    <Color x:Key="HnVue.Core.Color.PrimaryLight">#2E6DB4</Color>
    <Color x:Key="HnVue.Core.Color.Accent">#00AEEF</Color>

    <!-- ═══ Background Colors (PPT slide 5/6 dark navy spec) ═══ -->
    <Color x:Key="HnVue.Core.Color.BackgroundPage">#0d1527</Color>
    <Color x:Key="HnVue.Core.Color.BackgroundPanel">#1a2540</Color>
    <Color x:Key="HnVue.Core.Color.BackgroundCard">#1e2d4a</Color>

    <!-- ═══ Text Colors ═══ -->
    <Color x:Key="HnVue.Core.Color.TextPrimary">#FFFFFF</Color>
    <Color x:Key="HnVue.Core.Color.TextSecondary">#B0BEC5</Color>
    <Color x:Key="HnVue.Core.Color.TextDisabled">#546E7A</Color>

    <!-- ═══ Status Colors (IEC 62366 Safety-Critical) ═══ -->
    <!-- Safe/Idle: Dark theme green -->
    <Color x:Key="HnVue.Core.Color.StatusSafe">#00C853</Color>
    <!-- Warning: Dark theme amber -->
    <Color x:Key="HnVue.Core.Color.StatusWarning">#FFD600</Color>
    <!-- Blocked: Dark theme deep orange -->
    <Color x:Key="HnVue.Core.Color.StatusBlocked">#FF6D00</Color>
    <!-- Emergency: Dark theme red -->
    <Color x:Key="HnVue.Core.Color.StatusEmergency">#D50000</Color>

    <!-- ═══ Interactive Colors ═══ -->
    <Color x:Key="HnVue.Core.Color.ButtonPrimary">#1B4F8A</Color>
    <Color x:Key="HnVue.Core.Color.ButtonPrimaryHover">#2E6DB4</Color>
    <Color x:Key="HnVue.Core.Color.ButtonSecondary">Transparent</Color>
    <Color x:Key="HnVue.Core.Color.ButtonDanger">#D50000</Color>

    <!-- ═══ Border Colors ═══ -->
    <Color x:Key="HnVue.Core.Color.Border">#3B3B3B</Color>
    <Color x:Key="HnVue.Core.Color.BorderFocus">#00AEEF</Color>

    <!-- ═══ Typography ═══ -->
    <FontFamily x:Key="HnVue.Core.FontFamily">Segoe UI</FontFamily>
    <sys:Double x:Key="HnVue.Core.FontSize.XSmall">10</sys:Double>
    <sys:Double x:Key="HnVue.Core.FontSize.Small">11</sys:Double>
    <sys:Double x:Key="HnVue.Core.FontSize.Normal">13</sys:Double>
    <sys:Double x:Key="HnVue.Core.FontSize.Large">16</sys:Double>
    <sys:Double x:Key="HnVue.Core.FontSize.Header">20</sys:Double>
    <sys:Double x:Key="HnVue.Core.FontSize.Display">28</sys:Double>

    <!-- ═══ Spacing ═══ -->
    <sys:Double x:Key="HnVue.Core.Spacing.XSmall">4</sys:Double>
    <sys:Double x:Key="HnVue.Core.Spacing.Small">8</sys:Double>
    <sys:Double x:Key="HnVue.Core.Spacing.Medium">12</sys:Double>
    <sys:Double x:Key="HnVue.Core.Spacing.Normal">16</sys:Double>
    <sys:Double x:Key="HnVue.Core.Spacing.Large">24</sys:Double>
    <sys:Double x:Key="HnVue.Core.Spacing.XLarge">32</sys:Double>

    <!-- Thickness wrappers for Margin/Padding use -->
    <Thickness x:Key="HnVue.Core.Padding.XSmall">4</Thickness>
    <Thickness x:Key="HnVue.Core.Padding.Small">8</Thickness>
    <Thickness x:Key="HnVue.Core.Padding.Normal">16</Thickness>
    <Thickness x:Key="HnVue.Core.Padding.Large">24</Thickness>

    <!-- ═══ Corner Radii ═══ -->
    <CornerRadius x:Key="HnVue.Core.CornerRadius.None">0</CornerRadius>
    <CornerRadius x:Key="HnVue.Core.CornerRadius.Small">2</CornerRadius>
    <CornerRadius x:Key="HnVue.Core.CornerRadius.Normal">4</CornerRadius>
    <CornerRadius x:Key="HnVue.Core.CornerRadius.Large">8</CornerRadius>
    <CornerRadius x:Key="HnVue.Core.CornerRadius.Round">16</CornerRadius>

    <!-- ═══ Elevation / Opacity ═══ -->
    <sys:Double x:Key="HnVue.Core.Opacity.Disabled">0.38</sys:Double>
    <sys:Double x:Key="HnVue.Core.Opacity.Hover">0.08</sys:Double>
    <sys:Double x:Key="HnVue.Core.Opacity.Overlay">0.54</sys:Double>

    <!-- ═══ Section Badge Colors (PPT Slide 3/6 spec) ═══ -->
    <!-- Badge background: dark navy per PPT design token table -->
    <Color x:Key="HnVue.Core.Color.SectionBadgeBg">#2A3A5C</Color>
    <!-- Badge text: golden yellow per PPT slide 3: 12px/700/#f9e04b -->
    <Color x:Key="HnVue.Core.Color.SectionBadgeText">#F9E04B</Color>
    <!-- Detail panel header text: light blue per PPT slide 6: 11px/700/#7bc8f5 -->
    <Color x:Key="HnVue.Core.Color.DetailHeaderText">#7BC8F5</Color>
    <!-- Label uppercase style: per PPT slide 3: 10px/600/#7090b0 -->
    <Color x:Key="HnVue.Core.Color.LabelMuted">#7090B0</Color>

</ResourceDictionary>
