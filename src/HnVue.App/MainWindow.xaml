<mah:MetroWindow x:Class="HnVue.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:views="clr-namespace:HnVue.UI.Views;assembly=HnVue.UI"
                 Title="HnVue Console" Height="900" Width="1400"
                 Background="{DynamicResource HnVue.Background.Dark.Brush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource HnVue.Primary.Brush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <!-- Logo badge -->
                    <Border Background="{DynamicResource HnVue.Semantic.Brand.Accent}"
                            CornerRadius="4"
                            Width="28"
                            Height="28"
                            Margin="0,0,8,0">
                        <TextBlock Text="H"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                    </Border>
                    <TextBlock Text="HnVue Console"
                               Foreground="{DynamicResource HnVue.Text.Primary.Brush}"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource HnVue.Core.FontSize.Large}"
                               FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                </StackPanel>

                <!-- Right side of header: Emergency Stop always visible + auth-gated user info -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">

                    <!-- Emergency button — SWR-NF-UX-026 (Safety-Critical, HAZ-RAD) / Issue #11
                         MUST be outside auth Visibility binding — visible even on login screen.
                         IEC 62366: Emergency Stop is always accessible regardless of auth state. -->
                    <Button Content="&#x26D4;  STOP"
                            Style="{StaticResource HnVue.EmergencyStopButton}"
                            Command="{Binding EmergencyCommand}"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"/>

                    <!-- User info + Logout (visible only when authenticated) -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding CurrentUsername}"
                                   Foreground="{DynamicResource HnVue.Text.Primary.Brush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                        <TextBlock Text="{Binding CurrentRoleDisplay}"
                                   Foreground="{DynamicResource HnVue.Text.Secondary.Brush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>

                        <!-- Logout button with border styling -->
                        <Button Style="{x:Null}"
                                Background="Transparent"
                                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                                BorderThickness="1"
                                Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                                Height="32"
                                Padding="12,0"
                                Command="{Binding LogoutCommand}"
                                VerticalAlignment="Center"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xF3B1;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                                <TextBlock Text="로그아웃"
                                           FontSize="12"
                                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">

            <!-- 3-column main layout (visible when authenticated) -->
            <Grid Visibility="{Binding IsMainContentVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Patient List (Shell Region — resolved via DataTemplate) -->
                <Border Grid.Column="0" Background="{DynamicResource HnVue.Background.Panel.Brush}">
                    <ContentControl Content="{Binding PatientListViewModel}"/>
                </Border>

                <!-- Center Panel: Image Viewer (Shell Region — resolved via DataTemplate) -->
                <Border Grid.Column="1" Background="{DynamicResource HnVue.Background.Dark.Brush}" Margin="2,0">
                    <ContentControl Content="{Binding ImageViewerViewModel}"/>
                </Border>

                <!-- Right Panel: Workflow + Dose (Shell Regions — resolved via DataTemplate) -->
                <Border Grid.Column="2" Background="{DynamicResource HnVue.Background.Panel.Brush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ContentControl Grid.Row="0" Content="{Binding WorkflowViewModel}"/>
                        <ContentControl Grid.Row="1" Content="{Binding DoseDisplayViewModel}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Login overlay (visible when not authenticated) -->
            <Border Visibility="{Binding IsLoginVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="{DynamicResource HnVue.Background.Dark.Brush}">
                <views:LoginView x:Name="LoginViewControl" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- TLS Inactive Warning Banner — SWR-CS-079 (Security-related, HAZ-SEC) / Issue #13
             Permanent yellow banner shown when DICOM TLS is disabled. -->
        <Border Grid.Row="1" VerticalAlignment="Top"
                Background="{DynamicResource HnVue.Semantic.Status.Warning}"
                Padding="8,3"
                Visibility="{Binding IsTlsInactive, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="100">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7BA;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="13"
                           Foreground="Black"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBlock Text="TLS 비활성 — 네트워크 데이터가 암호화되지 않습니다. 설정에서 TLS를 활성화하십시오."
                           Foreground="Black"
                           FontWeight="SemiBold"
                           FontSize="12"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Session Timeout Countdown Banner — SWR-CS-075 (Security-related) / Issue #14
             Shown in footer area 3 minutes before session expires. -->
        <Border Grid.Row="2"
                Background="{DynamicResource HnVue.Semantic.Status.Blocked}"
                Padding="8,2"
                Visibility="{Binding IsTimeoutWarningVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="100"
                VerticalAlignment="Bottom">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE823;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="11"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBlock Text="{Binding SessionTimeoutCountdown, StringFormat='세션 만료까지 {0}초 — 활동하거나 다시 로그인하십시오'}"
                           Foreground="White"
                           FontSize="11"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Footer: Status Bar -->
        <StatusBar Grid.Row="2" Background="{DynamicResource HnVue.Component.StatusBar.Bg}">
            <StatusBarItem>
                <TextBlock Text="{Binding ActiveNavItem, StringFormat='섹션: {0}', FallbackValue='준비'}"
                           Foreground="{DynamicResource HnVue.Component.StatusBar.Text}"
                           FontSize="{DynamicResource HnVue.Core.FontSize.Small}"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <!-- DICOM connection status indicator -->
                    <Ellipse Width="8" Height="8"
                             VerticalAlignment="Center"
                             Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource HnVue.Component.StatusBar.Safe}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDicomConnected, FallbackValue=False}" Value="False">
                                        <Setter Property="Fill" Value="{DynamicResource HnVue.Component.StatusBar.Emergency}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontSize="{DynamicResource HnVue.Core.FontSize.Small}"
                               FontFamily="{DynamicResource HnVue.Core.FontFamily}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Connected"/>
                                <Setter Property="Foreground" Value="{DynamicResource HnVue.Component.StatusBar.Safe}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDicomConnected, FallbackValue=False}" Value="False">
                                        <Setter Property="Text" Value="Disconnected"/>
                                        <Setter Property="Foreground" Value="{DynamicResource HnVue.Component.StatusBar.Emergency}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</mah:MetroWindow>
