<UserControl x:Class="HnVue.UI.Views.StudylistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <!--
        @MX:NOTE StudylistView — Study list with PACS server selection and period filters.
                 PPT 슬라이드 7 (Studylist 2안): prev/next navigation, PACS dropdown, period filters.
                 Columns: PatientId, AccessionNumber, StudyDate, BodyPart, Description.
    -->
    <Grid Background="{DynamicResource HnVue.Semantic.Surface.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Header: nav + title + PACS server -->
            <RowDefinition Height="Auto"/> <!-- Filter buttons + search -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
            <RowDefinition Height="Auto"/> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Row 0: Header — prev/next + title + PACS server dropdown -->
        <Border Grid.Row="0"
                Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                BorderThickness="0,0,0,1"
                Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Previous button — Segoe MDL2 ChevronLeft -->
                <Button Grid.Column="0"
                        Content="&#xE76B;"
                        FontFamily="Segoe MDL2 Assets"
                        Command="{Binding NavigatePreviousCommand}"
                        Style="{StaticResource HnVue.OutlineButton}"
                        Width="32" Height="32"
                        Margin="0,0,4,0"
                        ToolTip="Previous"/>

                <!-- Next button — Segoe MDL2 ChevronRight -->
                <Button Grid.Column="1"
                        Content="&#xE76C;"
                        FontFamily="Segoe MDL2 Assets"
                        Command="{Binding NavigateNextCommand}"
                        Style="{StaticResource HnVue.OutlineButton}"
                        Width="32" Height="32"
                        Margin="0,0,12,0"
                        ToolTip="Next"/>

                <!-- Section title -->
                <TextBlock Grid.Column="2"
                           Text="Study List"
                           Style="{StaticResource HnVue.SectionHeader}"
                           VerticalAlignment="Center"/>

                <!-- PACS label -->
                <TextBlock Grid.Column="3"
                           Text="PACS:"
                           Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Margin="0,0,6,0"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>

                <!-- PACS server ComboBox -->
                <ComboBox Grid.Column="4"
                          ItemsSource="{Binding PacsServers}"
                          SelectedItem="{Binding SelectedPacsServer}"
                          Width="120"
                          Height="30"
                          VerticalAlignment="Center"
                          FontSize="13"
                          FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
            </Grid>
        </Border>

        <!-- Row 1: Period filter buttons + search -->
        <Grid Grid.Row="1"
              Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
              Margin="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- Period filter buttons (matches PatientListView pattern) -->
            <ScrollViewer Grid.Column="0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="12,6,8,6">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Today"
                            Command="{Binding FilterByPeriodCommand}"
                            CommandParameter="Today"
                            Style="{StaticResource HnVue.OutlineButton}"
                            Height="28" Padding="10,0" Margin="0,0,4,0"
                            FontSize="12"
                            FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                    <Button Content="3Days"
                            Command="{Binding FilterByPeriodCommand}"
                            CommandParameter="3Days"
                            Style="{StaticResource HnVue.OutlineButton}"
                            Height="28" Padding="10,0" Margin="0,0,4,0"
                            FontSize="12"
                            FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                    <Button Content="1Week"
                            Command="{Binding FilterByPeriodCommand}"
                            CommandParameter="1Week"
                            Style="{StaticResource HnVue.OutlineButton}"
                            Height="28" Padding="10,0" Margin="0,0,4,0"
                            FontSize="12"
                            FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                    <Button Content="All"
                            Command="{Binding FilterByPeriodCommand}"
                            CommandParameter="All"
                            Style="{StaticResource HnVue.OutlineButton}"
                            Height="28" Padding="10,0" Margin="0,0,4,0"
                            FontSize="12"
                            FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                    <Button Content="1Month"
                            Command="{Binding FilterByPeriodCommand}"
                            CommandParameter="1Month"
                            Style="{StaticResource HnVue.OutlineButton}"
                            Height="28" Padding="10,0"
                            FontSize="12"
                            FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Search box -->
            <Border Grid.Column="1"
                    Margin="0,6,12,6"
                    Height="28"
                    CornerRadius="4"
                    Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                    BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                    BorderThickness="1"
                    Padding="8,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Search icon — Segoe MDL2 -->
                    <TextBlock Grid.Column="0"
                               Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                             BorderThickness="0"
                             FontSize="12"
                             VerticalAlignment="Center"
                             CaretBrush="{DynamicResource HnVue.Semantic.Brand.Accent}"
                             FontFamily="{DynamicResource HnVue.Core.FontFamily}">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Resources>
                                    <VisualBrush x:Key="WatermarkBrush" TileMode="None" Stretch="None" AlignmentX="Left">
                                        <VisualBrush.Visual>
                                            <TextBlock Text="Search studies..."
                                                       Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                                       FontSize="12"
                                                       Margin="0"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Style.Resources>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background" Value="{StaticResource WatermarkBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 2: Study DataGrid — columns match StudyRecord properties -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Studies}"
                  SelectedItem="{Binding SelectedStudy}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  RowHeight="40"
                  Background="Transparent"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                  ColumnHeaderHeight="36"
                  Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                  FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                  FontSize="13">
            <DataGrid.Columns>
                <!-- PatientId — StudyRecord.PatientId -->
                <DataGridTextColumn Header="Patient ID"
                                    Binding="{Binding PatientId}"
                                    Width="130"/>
                <!-- AccessionNumber — StudyRecord.AccessionNumber (nullable) -->
                <DataGridTextColumn Header="Acc No"
                                    Binding="{Binding AccessionNumber}"
                                    Width="130"/>
                <!-- StudyDate — StudyRecord.StudyDate (DateTimeOffset) -->
                <DataGridTextColumn Header="Exam Date"
                                    Binding="{Binding StudyDate, StringFormat=\{0:yyyy-MM-dd\}}"
                                    Width="110"/>
                <!-- BodyPart — StudyRecord.BodyPart (nullable, used as Modality substitute) -->
                <DataGridTextColumn Header="Body Part"
                                    Binding="{Binding BodyPart}"
                                    Width="100"/>
                <!-- Description — StudyRecord.Description (nullable) -->
                <DataGridTextColumn Header="Description"
                                    Binding="{Binding Description}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 3: Status bar -->
        <Border Grid.Row="3"
                Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Error message (hidden when null/empty) -->
                <TextBlock Grid.Column="0"
                           Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource HnVue.Semantic.Status.Emergency}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}">
                    <TextBlock.Visibility>
                        <Binding Path="ErrorMessage" Converter="{StaticResource NullToVisibilityConverter}"/>
                    </TextBlock.Visibility>
                </TextBlock>

                <!-- Study count -->
                <TextBlock Grid.Column="1"
                           FontSize="12"
                           Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                           VerticalAlignment="Center"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}">
                    <Run Text="{Binding Studies.Count, Mode=OneWay}"/>
                    <Run Text=" studies"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</UserControl>
