<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:common="clr-namespace:HnVue.UI.Components.Common"
                    xmlns:medical="clr-namespace:HnVue.UI.Components.Medical"
                    xmlns:layout="clr-namespace:HnVue.UI.Components.Layout">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Styles/ButtonStyles.xaml"/>
        <ResourceDictionary Source="../Styles/InputStyles.xaml"/>
        <ResourceDictionary Source="../Styles/CardStyles.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ==================================================================== -->
    <!-- COMMON COMPONENTS                                                     -->
    <!-- ==================================================================== -->

    <!-- MedicalButton Style -->
    <Style TargetType="common:MedicalButton" BasedOn="{StaticResource ButtonBase}">
        <Setter Property="Background" Value="{StaticResource Primary.Main}"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Style.Triggers>
            <Trigger Property="ButtonType" Value="Secondary">
                <Setter Property="Background" Value="{StaticResource Neutral.Surface}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{StaticResource Neutral.Border}"/>
            </Trigger>
            <Trigger Property="ButtonType" Value="Danger">
                <Setter Property="Background" Value="{StaticResource Semantic.Error}"/>
            </Trigger>
            <Trigger Property="ButtonType" Value="Success">
                <Setter Property="Background" Value="{StaticResource Semantic.Success}"/>
            </Trigger>
            <Trigger Property="IsCritical" Value="True">
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="BorderBrush" Value="{StaticResource Semantic.Warning}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- MedicalTextBox Style -->
    <Style TargetType="common:MedicalTextBox" BasedOn="{StaticResource InputBase}">
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Neutral.Border}"/>
        <Setter Property="Background" Value="{StaticResource Neutral.Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource Neutral.Text}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Primary.Main}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource Primary.Light}"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource Primary.Main}"/>
                <Setter Property="BorderThickness" Value="2"/>
            </Trigger>
            <Trigger Property="HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource Semantic.Error}"/>
                <Setter Property="BorderThickness" Value="2"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.6"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Card Style -->
    <Style TargetType="common:Card">
        <Setter Property="Background" Value="{StaticResource Neutral.Surface}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="8"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" Opacity="0.3" BlurRadius="12" ShadowDepth="4"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="common:Card">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}"
                            Effect="{TemplateBinding Effect}">
                        <StackPanel>
                            <!-- Header Section -->
                            <ContentPresenter Content="{TemplateBinding Header}"
                                            ContentTemplate="{TemplateBinding HeaderTemplate}"
                                            ContentStringFormat="{TemplateBinding HeaderStringFormat}"/>
                            <!-- Main Content -->
                            <ContentPresenter Content="{TemplateBinding Content}"/>
                            <!-- Footer Section -->
                            <ContentPresenter Content="{TemplateBinding Footer}"
                                            ContentTemplate="{TemplateBinding FooterTemplate}"
                                            ContentStringFormat="{TemplateBinding FooterStringFormat}"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modal Style -->
    <Style TargetType="common:Modal">
        <Setter Property="Background" Value="{StaticResource Neutral.Surface}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="MaxWidth" Value="600"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="common:Modal">
                    <Grid Background="#80000000" x:Name="Overlay">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                MaxWidth="{TemplateBinding MaxWidth}"
                                HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                Effect="{StaticResource CardShadow}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Grid Grid.Row="0" Height="56" Margin="24,16,24,0">
                                    <TextBlock Text="{TemplateBinding Title}"
                                               Style="{StaticResource TextStyle.H2}"
                                               VerticalAlignment="Center"/>
                                    <Button HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Width="32" Height="32"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Visibility="{TemplateBinding HasCloseButton, Converter={StaticResource BoolToVisibility}}"
                                            Command="{TemplateBinding CloseCommand}">
                                        <TextBlock Text="×" FontSize="24" Foreground="{StaticResource Neutral.Text}"/>
                                    </Button>
                                </Grid>

                                <!-- Content -->
                                <ContentPresenter Grid.Row="1"
                                                Content="{TemplateBinding Content}"
                                                Margin="24,16"/>

                                <!-- Footer -->
                                <Border Grid.Row="2"
                                        Height="64"
                                        BorderBrush="{StaticResource Neutral.Border}"
                                        BorderThickness="0,1,0,0"
                                        Padding="24,0"
                                        Visibility="{TemplateBinding ShowFooter, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                        <Button Content="취소"
                                                Style="{StaticResource Button.Secondary}"
                                                Margin="0,0,8,0"
                                                Command="{TemplateBinding CancelCommand}"/>
                                        <Button Content="확인"
                                                Style="{StaticResource Button.Primary}"
                                                Command="{TemplateBinding ConfirmCommand}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Toast Style -->
    <Style TargetType="common:Toast">
        <Setter Property="Background" Value="{StaticResource Neutral.Surface}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="MaxWidth" Value="400"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Margin" Value="0,0,0,24"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" Opacity="0.4" BlurRadius="16" ShadowDepth="4"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="common:Toast">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}"
                            MaxWidth="{TemplateBinding MaxWidth}"
                            HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalAlignment}"
                            Margin="{TemplateBinding Margin}"
                            Effect="{TemplateBinding Effect}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                                <Ellipse Width="24" Height="24">
                                    <Ellipse.Fill>
                                        <MultiBinding Converter="{StaticResource ToastTypeToColorConverter}">
                                            <Binding Source="{StaticResource Semantic.Success}"/>
                                            <Binding Source="{StaticResource Semantic.Warning}"/>
                                            <Binding Source="{StaticResource Semantic.Error}"/>
                                            <Binding Source="{StaticResource Semantic.Info}"/>
                                        </MultiBinding>
                                    </Ellipse.Fill>
                                </Ellipse>

                            <!-- Message -->
                                <TextBlock Text="{TemplateBinding Message}"
                                           Style="{StaticResource TextStyle.Body}"
                                           Margin="12,0"
                                           VerticalAlignment="Center"/>

                            <!-- Close Button -->
                            <Button Grid.Column="2"
                                    Width="24" Height="24"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{TemplateBinding CloseCommand}">
                                <TextBlock Text="×" FontSize="20" Foreground="{StaticResource Neutral.TextMuted}"/>
                            </Button>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================================================================== -->
    <!-- MEDICAL COMPONENTS                                                     -->
    <!-- ==================================================================== -->

    <!-- PatientInfoCard Style -->
    <Style TargetType="medical:PatientInfoCard">
        <Setter Property="Background" Value="{StaticResource Neutral.Surface}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Neutral.Border}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Margin" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="medical:PatientInfoCard">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}"
                            Margin="{TemplateBinding Margin}"
                            Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Patient Icon -->
                                <Ellipse Grid.Column="0" Width="48" Height="48"
                                         Fill="{StaticResource Primary.Light}"
                                         Margin="0,0,16,0">
                                    <Ellipse.OpacityMask>
                                        <VisualBrush Stretch="Fill" Visual="{StaticResource PatientIcon}"/>
                                    </Ellipse.OpacityMask>
                                </Ellipse>

                                <!-- Patient ID & Name -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{TemplateBinding PatientId}"
                                               Style="{StaticResource TextStyle.Caption}"/>
                                    <TextBlock Text="{TemplateBinding PatientName}"
                                               Style="{StaticResource TextStyle.H2}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Patient Details -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Date of Birth -->
                                <TextBlock Grid.Column="0" Grid.Row="0"
                                           Text="생년월일"
                                           Style="{StaticResource TextStyle.Caption}"/>
                                <TextBlock Grid.Column="0" Grid.Row="1"
                                           Style="{StaticResource TextStyle.Body}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0:yyyy-MM-dd}">
                                            <Binding Path="DateOfBirth"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>

                                <!-- Age -->
                                <TextBlock Grid.Column="1" Grid.Row="0"
                                           Text="나이"
                                           Style="{StaticResource TextStyle.Caption}"/>
                                <TextBlock Grid.Column="1" Grid.Row="1"
                                           Text="{TemplateBinding Age}"
                                           Style="{StaticResource TextStyle.Body}"/>

                                <!-- Sex -->
                                <TextBlock Grid.Column="2" Grid.Row="0"
                                           Text="성별"
                                           Style="{StaticResource TextStyle.Caption}"/>
                                <TextBlock Grid.Column="2" Grid.Row="1"
                                           Style="{StaticResource TextStyle.Body}">
                                    <TextBlock.Text>
                                        <Binding Path="Sex">
                                            <Binding.Converter>
                                                <common:SexConverter/>
                                            </Binding.Converter>
                                        </Binding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- StudyThumbnail Style -->
    <Style TargetType="medical:StudyThumbnail">
        <Setter Property="Background" Value="{StaticResource Neutral.Surface}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Margin" Value="8"/>
        <Setter Property="Width" Value="200"/>
        <Setter Property="Height" Value="200"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="medical:StudyThumbnail">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}"
                            Margin="{TemplateBinding Margin}"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Cursor="{TemplateBinding Cursor}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Thumbnail Image -->
                            <Border Grid.Row="0"
                                    CornerRadius="4"
                                    Background="{StaticResource Neutral.Border}">
                                <Image Source="{TemplateBinding ThumbnailImage}"
                                       Stretch="Uniform"
                                       Margin="4"/>
                            </Border>

                            <!-- Study Info Overlay -->
                            <Border Grid.Row="1"
                                    CornerRadius="0,0,4,4"
                                    Background="{StaticResource Neutral.Background}"
                                    Padding="8,4">
                                <StackPanel>
                                    <TextBlock Text="{TemplateBinding Modality}"
                                               Style="{StaticResource TextStyle.Caption}"
                                               Foreground="{StaticResource Primary.Light}"/>
                                    <TextBlock Text="{TemplateBinding StudyDescription}"
                                               Style="{StaticResource TextStyle.Body}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="180"/>
                                </StackPanel>
                            </Border>

                            <!-- Status Badge -->
                                <TextBlock Text="완료"
                                           Style="{StaticResource TextStyle.Caption}"
                                           Foreground="White"
                                           Padding="8,4"
                                           Background="{StaticResource Semantic.Success}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Background" Value="{StaticResource Neutral.TextMuted}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StudyStatus}" Value="InProgress">
                                                    <Setter Property="Background" Value="{StaticResource Semantic.Info}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StudyStatus}" Value="Completed">
                                                    <Setter Property="Background" Value="{StaticResource Semantic.Success}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StudyStatus}" Value="Error">
                                                    <Setter Property="Background" Value="{StaticResource Semantic.Error}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- AcquisitionPreview Style -->
    <Style TargetType="medical:AcquisitionPreview">
        <Setter Property="Background" Value="#000000"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="{StaticResource Neutral.Border}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="medical:AcquisitionPreview">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid>
                            <!-- Live Image -->
                            <Image Source="{TemplateBinding LiveImage}"
                                   Stretch="Uniform"
                                   Margin="4"/>

                            <!-- Exposure In Progress Indicator -->
                                <Grid Background="#80000000" Visibility="Collapsed">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ExposureInProgress}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse Width="80" Height="80"
                                                 Stroke="{StaticResource Semantic.Error}"
                                                 StrokeThickness="4"
                                                 Fill="Transparent">
                                            <Ellipse.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                           From="1" To="0.2" Duration="0:0:1"
                                                                           AutoReverse="True"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>
                                        <TextBlock Text="EXPOSURE IN PROGRESS"
                                                   Style="{StaticResource TextStyle.H2}"
                                                   Foreground="{StaticResource Semantic.Error}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,16,0,0"/>
                                    </StackPanel>
                                </Grid>

                            <!-- Body Part & View Position -->
                            <Border HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="#80000000"
                                    CornerRadius="4"
                                    Padding="12,8"
                                    Margin="8">
                                <StackPanel>
                                    <TextBlock Text="{TemplateBinding BodyPart, Converter={StaticResource EnumDescriptionConverter}}"
                                               Style="{StaticResource TextStyle.Caption}"/>
                                    <TextBlock Text="{TemplateBinding ViewPosition, Converter={StaticResource EnumDescriptionConverter}}"
                                               Style="{StaticResource TextStyle.Body}"
                                               Foreground="{StaticResource Primary.Light}"/>
                                </StackPanel>
                            </Border>

                            <!-- Exposure Count -->
                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Background="#80000000"
                                    CornerRadius="4"
                                    Padding="12,8"
                                    Margin="8">
                                <StackPanel>
                                    <TextBlock Text="Exposures"
                                               Style="{StaticResource TextStyle.Caption}"/>
                                    <TextBlock Text="{TemplateBinding ExposureCount, StringFormat={}{0}}"
                                               Style="{StaticResource TextStyle.H2}"
                                               Foreground="{StaticResource Primary.Light}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================================================================== -->
    <!-- LAYOUT COMPONENTS                                                      -->
    <!-- ==================================================================== -->

    <!-- Sidebar Style -->
    <Style TargetType="layout:Sidebar">
        <Setter Property="Background" Value="{StaticResource Neutral.Surface}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="BorderBrush" Value="{StaticResource Neutral.Border}"/>
        <Setter Property="Width" Value="240"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="layout:Sidebar">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Width="{TemplateBinding Width}">
                        <StackPanel>
                            <!-- Logo -->
                            <ContentPresenter Content="{TemplateBinding Logo}"
                                            Margin="24,20"/>
                            <!-- Navigation Items -->
                            <ItemsControl ItemsSource="{TemplateBinding MenuItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource Button.Secondary}"
                                                HorizontalAlignment="Stretch"
                                                Margin="8,4"
                                                Command="{Binding Command}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Icon}" Margin="12,0"/>
                                                <TextBlock Text="{Binding Label}" Style="{StaticResource TextStyle.Body}"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Footer Content -->
                            <ContentPresenter Content="{TemplateBinding FooterContent}"
                                            Margin="16,0,16,16"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Header Style -->
    <Style TargetType="layout:Header">
        <Setter Property="Background" Value="{StaticResource Neutral.Surface}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Neutral.Border}"/>
        <Setter Property="Height" Value="56"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="layout:Header">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Height="{TemplateBinding Height}"
                            Padding="24,0">
                        <Grid>
                            <!-- Left Content -->
                            <ContentPresenter Content="{TemplateBinding LeftContent}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"/>
                            <!-- Title -->
                            <TextBlock Text="{TemplateBinding Title}"
                                       Style="{StaticResource TextStyle.H2}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <!-- Right Content -->
                            <ContentPresenter Content="{TemplateBinding RightContent}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- StatusBar Style -->
    <Style TargetType="layout:StatusBar">
        <Setter Property="Background" Value="{StaticResource Neutral.Background}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="BorderBrush" Value="{StaticResource Neutral.Border}"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="layout:StatusBar">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Height="{TemplateBinding Height}"
                            Padding="16,0">
                        <Grid>
                            <!-- Left: Status Messages -->
                            <ContentPresenter Content="{TemplateBinding StatusMessage}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"/>
                            <!-- Right: Additional Info -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding ConnectionStatus}"
                                           Style="{StaticResource TextStyle.Caption}"
                                           Margin="0,0,16,0"/>
                                <TextBlock Text="{TemplateBinding CurrentTime}"
                                           Style="{StaticResource TextStyle.Caption}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
