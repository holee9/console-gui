<!--
    @MX:NOTE WorkflowView — Acquisition workflow control panel.
             PLACEMENT: Right panel of MainWindow (260px wide, variable height ~60% of window).
             Sits above DoseDisplayView in a vertical stack inside the 260px right border.
             IEC 62366: Emergency Stop always visible in this panel AND in MainWindow header.
             Issue #49: compact vertical layout for right panel.
    @MX:WARN Emergency Stop button in this view MUST remain IsEnabled=True at all times.
             AbortCommand is bound — it triggers immediate generator stop (≤100ms, synchronous).
             The keyboard Escape binding applies globally to this UserControl.
-->
<UserControl x:Class="HnVue.UI.Views.WorkflowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:HnVue.UI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="260"
             Background="{DynamicResource HnVue.Semantic.Surface.Panel}">

    <!-- IEC 62366: Escape key always triggers Emergency Stop regardless of focus -->
    <UserControl.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding AbortCommand}"
                    CommandParameter="EmergencyStop" />
    </UserControl.InputBindings>
    <UserControl.Resources>
        <converters:SafeStateToColorConverter x:Key="SafeStateToColor"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Row 0: Section title bar -->
            <RowDefinition Height="36"/>
            <!-- Row 1: SafeState indicator badge -->
            <RowDefinition Height="Auto"/>
            <!-- Row 2: Status message -->
            <RowDefinition Height="Auto"/>
            <!-- Row 3: Action buttons (PREP + EXPOSE) -->
            <RowDefinition Height="Auto"/>
            <!-- Row 4: Spacer -->
            <RowDefinition Height="*"/>
            <!-- Row 5: Emergency Stop (always at bottom, always visible) -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Row 0: Section title ── -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                BorderThickness="0,0,0,1"
                Padding="12,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- X-ray acquisition icon: Segoe MDL2 &#xECAD; (Camera/Photo) -->
                <TextBlock Text="&#xE722;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="14"
                           Foreground="{DynamicResource HnVue.Semantic.Brand.Accent}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBlock Text="Acquisition"
                           Style="{StaticResource HnVue.SectionHeader}"
                           FontSize="{DynamicResource HnVue.Core.FontSize.Normal}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Row 1: SafeState indicator bar ── -->
        <!--
            @MX:ANCHOR SafeState indicator — bound to SafeStateToColorConverter.
                       Color: Idle=gray, ReadyToExpose=green, Exposing=red, SafeState=blue.
                       Issue #31 / SWR-NF-SC-041.
        -->
        <Border Grid.Row="1"
                Background="{Binding CurrentSafeState, Converter={StaticResource SafeStateToColor}}"
                Padding="12,6"
                Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7BA;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="11"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBlock Text="{Binding SafeStateLabel}"
                           Foreground="White"
                           FontSize="{DynamicResource HnVue.Core.FontSize.Normal}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Text=" | "
                           Foreground="White"
                           Opacity="0.6"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentState}"
                           Foreground="White"
                           FontSize="{DynamicResource HnVue.Core.FontSize.Small}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Row 2: Status message ── -->
        <Border Grid.Row="2" Padding="12,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                       FontSize="{DynamicResource HnVue.Core.FontSize.Small}"
                       TextWrapping="Wrap"
                       LineHeight="18"/>
        </Border>

        <!-- ── Row 3: Action buttons ── -->
        <StackPanel Grid.Row="3" Margin="12,4,12,0">

            <!-- PREPARE button -->
            <Button Command="{Binding PrepareExposureCommand}"
                    Style="{StaticResource HnVue.OutlineButton}"
                    Height="40"
                    Margin="0,0,0,8"
                    HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE768;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="PREPARE"
                               FontWeight="SemiBold"
                               FontSize="{DynamicResource HnVue.Core.FontSize.Normal}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- EXPOSE button — only enabled in ReadyToExpose state -->
            <Button Command="{Binding TriggerExposureCommand}"
                    Style="{StaticResource HnVue.PrimaryButton}"
                    Height="44"
                    HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE7C8;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="EXPOSE"
                               FontWeight="Bold"
                               FontSize="{DynamicResource HnVue.Core.FontSize.Normal}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- ── Row 4: Spacer (empty) ── -->
        <Border Grid.Row="4"/>

        <!-- ── Row 5: Emergency Stop ── -->
        <!--
            @MX:WARN Emergency Stop (AbortCommand) — ALWAYS visible, ALWAYS IsEnabled=True.
                     Placed at bottom of right panel for consistent gloved-hand access.
                     Escape key binding above also triggers this command.
                     DO NOT set IsEnabled binding. DO NOT use Collapsed/Hidden visibility.
                     IEC 62366 §5.2: minimum 44×44px touch target; we use 56px height.
        -->
        <Button x:Name="EmergencyStopButton"
                Grid.Row="5"
                Command="{Binding AbortCommand}"
                Style="{StaticResource HnVue.EmergencyStopButton}"
                Margin="12,8,12,12"
                HorizontalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="&#xE71A;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="18"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="STOP"
                               FontWeight="Bold"
                               FontSize="{DynamicResource HnVue.Core.FontSize.Large}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="비상 정지  (Esc)"
                               FontSize="9"
                               Opacity="0.85"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Button>

    </Grid>
</UserControl>
