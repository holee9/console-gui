<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:HnVue.UI.Components.Common">

    <!-- ═══════════════════════════════════════════════════════════
         DS2026 Modal Component
         IEC 62366 compliant modal dialogs
         ═══════════════════════════════════════════════════════════ -->

    <Style x:Key="DS2026.Modal.Overlay" TargetType="Border">
        <Setter Property="Background" Value="#000000" />
        <Setter Property="Opacity" Value="0.54" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <Style TargetType="local:Modal">
        <Setter Property="Background" Value="{StaticResource DS2026.Brush.Surface}" />
        <Setter Property="MaxWidth" Value="600" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:Modal">
                    <Grid Background="Transparent">
                        <!-- Overlay -->
                        <Border Style="{StaticResource DS2026.Modal.Overlay}">
                            <Border.InputBindings>
                                <MouseBinding Command="{Binding CloseCommand}" MouseAction="LeftClick" />
                            </Border.InputBindings>
                        </Border>

                        <!-- Modal Content -->
                        <Border Width="{TemplateBinding Width}"
                                MaxWidth="{TemplateBinding MaxWidth}"
                                Height="{TemplateBinding Height}"
                                MaxHeight="{TemplateBinding MaxHeight}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource DS2026.CornerRadius.XL}"
                                Padding="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Effect="{StaticResource DS2026.Elevation.Modal}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Border Grid.Row="0"
                                        Padding="{StaticResource DS2026.Padding.MD}"
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="{StaticResource DS2026.Brush.Border}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ContentPresenter Grid.Column="0"
                                                          Content="{TemplateBinding Header}"
                                                          TextElement.FontSize="{StaticResource DS2026.FontSize.H2}"
                                                          TextElement.FontWeight="SemiBold"
                                                          TextElement.Foreground="{StaticResource DS2026.Brush.Text}"
                                                          VerticalAlignment="Center" />

                                        <Button Grid.Column="1"
                                                Command="{Binding CloseCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                                Width="32"
                                                Height="32"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Margin="0">
                                            <Path Data="M 8 8 L 24 24 M 24 8 L 8 24"
                                                  Stroke="{StaticResource DS2026.Brush.TextMuted}"
                                                  StrokeThickness="2"
                                                  Stretch="Uniform"
                                                  Width="16"
                                                  Height="16" />
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3E3E5E" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Body -->
                                <ScrollViewer Grid.Row="1"
                                              Padding="{StaticResource DS2026.Padding.MD}"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ContentPresenter Content="{TemplateBinding Content}" />
                                </ScrollViewer>

                                <!-- Footer -->
                                <Border Grid.Row="2"
                                        Padding="{StaticResource DS2026.Padding.MD}"
                                        BorderThickness="0,1,0,0"
                                        BorderBrush="{StaticResource DS2026.Brush.Border}">
                                    <ItemsControl ItemsSource="{TemplateBinding FooterActions}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            IsItemsHost="True" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style>
                                                <Setter Property="FrameworkElement.Margin" Value="8,0,0,0" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                    </ItemsControl>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
