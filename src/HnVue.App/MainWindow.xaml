<mah:MetroWindow x:Class="HnVue.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:views="clr-namespace:HnVue.UI.Views;assembly=HnVue.UI"
                 Title="HnVue Console" Height="900" Width="1400"
                 Background="{DynamicResource HnVue.Background.Dark.Brush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/><!-- 60px: IEC 62366 Emergency Stop minimum touch target -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0d1b36" BorderBrush="#2e4070" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo text -->
                <TextBlock Grid.Column="0"
                           Text="HnVUE"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#7bc8f5"
                           FontFamily="Malgun Gothic"
                           VerticalAlignment="Center"
                           Margin="10,0,12,0"/>

                <!-- Navigation tabs — PPT Slide 4 spec (visible when authenticated) -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Stretch"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">

                    <!-- Nav button style -->
                    <StackPanel.Resources>
                        <Style x:Key="NavButton" TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="#a0b4cc"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontFamily" Value="Malgun Gothic"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="Height" Value="30"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2e4070"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
                            <Setter Property="Background" Value="#2e4070"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </StackPanel.Resources>

                    <Button Content="Worklist" Style="{StaticResource NavButtonActive}"/>
                    <Button Content="Study" Style="{StaticResource NavButton}"/>
                    <Button Content="Report" Style="{StaticResource NavButton}"/>
                    <Button Content="Teaching File" Style="{StaticResource NavButton}"/>
                    <Button Content="Admin" Style="{StaticResource NavButton}"/>
                    <Button Content="Statistics" Style="{StaticResource NavButton}"/>
                </StackPanel>

                <!-- App title fallback — visible only when NOT authenticated -->
                <TextBlock Grid.Column="1"
                           Text="HnVue Console"
                           Foreground="{DynamicResource HnVue.Text.Primary.Brush}"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0"
                           FontSize="{DynamicResource HnVue.Core.FontSize.Large}"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Right side of header: Emergency Stop always visible + auth-gated user info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">

                    <!-- Emergency button — SWR-NF-UX-026 (Safety-Critical, HAZ-RAD) / Issue #11
                         MUST be outside auth Visibility binding — visible even on login screen.
                         IEC 62366: Emergency Stop is always accessible regardless of auth state. -->
                    <Button Content="&#x26D4;  STOP"
                            Style="{StaticResource HnVue.EmergencyStopButton}"
                            Command="{Binding EmergencyCommand}"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"/>

                    <!-- User info + Logout (visible only when authenticated) -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding CurrentUsername}"
                                   Foreground="#7bc8f5"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"
                                   FontFamily="Malgun Gothic"/>
                        <TextBlock Text="{Binding CurrentRoleDisplay}"
                                   Foreground="#a0b4cc"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontFamily="Malgun Gothic"/>

                        <!-- Logout button -->
                        <Button Style="{x:Null}"
                                Background="Transparent"
                                BorderBrush="#2e4070"
                                BorderThickness="1"
                                Foreground="#a0b4cc"
                                Height="22"
                                Padding="8,0"
                                Command="{Binding LogoutCommand}"
                                VerticalAlignment="Center"
                                FontSize="11"
                                FontFamily="Malgun Gothic"
                                Cursor="Hand"
                                Content="로그아웃"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">

            <!-- Single view content region — NavigationService sets CurrentView to the active ViewModel.
                 Each ViewModel is resolved to its View via implicit DataTemplates in HnVue.UI ResourceDictionary.
                 Replaces the fixed 3-column grid per DESIGN_PLAN_v2.md (team-design request). -->
            <ContentControl x:Name="MainContentControl"
                            Content="{Binding CurrentView}"
                            Visibility="{Binding IsMainContentVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- Login overlay (visible when not authenticated) -->
            <Border Visibility="{Binding IsLoginVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Background="{DynamicResource HnVue.Background.Dark.Brush}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <views:LoginView x:Name="LoginViewControl" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            </Border>
        </Grid>

        <!-- TLS Inactive Warning Banner — SWR-CS-079 (Security-related, HAZ-SEC) / Issue #13
             Permanent yellow banner shown when DICOM TLS is disabled. -->
        <Border Grid.Row="1" VerticalAlignment="Top"
                Background="{DynamicResource HnVue.Semantic.Status.Warning}"
                Padding="8,3"
                Visibility="{Binding IsTlsInactive, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="100">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7BA;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="13"
                           Foreground="Black"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBlock Text="TLS 비활성 — 네트워크 데이터가 암호화되지 않습니다. 설정에서 TLS를 활성화하십시오."
                           Foreground="Black"
                           FontWeight="SemiBold"
                           FontSize="12"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Session Timeout Countdown Banner — SWR-CS-075 (Security-related) / Issue #14
             Shown in footer area 3 minutes before session expires. -->
        <Border Grid.Row="2"
                Background="{DynamicResource HnVue.Semantic.Status.Blocked}"
                Padding="8,2"
                Visibility="{Binding IsTimeoutWarningVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="100"
                VerticalAlignment="Bottom">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE823;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="11"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBlock Text="{Binding SessionTimeoutCountdown, StringFormat='세션 만료까지 {0}초 — 활동하거나 다시 로그인하십시오'}"
                           Foreground="White"
                           FontSize="11"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Footer: Status Bar -->
        <StatusBar Grid.Row="2" Background="{DynamicResource HnVue.Component.StatusBar.Bg}">
            <StatusBarItem>
                <TextBlock Text="{Binding ActiveNavItem, StringFormat='섹션: {0}', FallbackValue='준비'}"
                           Foreground="{DynamicResource HnVue.Component.StatusBar.Text}"
                           FontSize="{DynamicResource HnVue.Core.FontSize.Small}"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <!-- DICOM connection status indicator -->
                    <Ellipse Width="8" Height="8"
                             VerticalAlignment="Center"
                             Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource HnVue.Component.StatusBar.Safe}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDicomConnected, FallbackValue=False}" Value="False">
                                        <Setter Property="Fill" Value="{DynamicResource HnVue.Component.StatusBar.Emergency}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontSize="{DynamicResource HnVue.Core.FontSize.Small}"
                               FontFamily="{DynamicResource HnVue.Core.FontFamily}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Connected"/>
                                <Setter Property="Foreground" Value="{DynamicResource HnVue.Component.StatusBar.Safe}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDicomConnected, FallbackValue=False}" Value="False">
                                        <Setter Property="Text" Value="Disconnected"/>
                                        <Setter Property="Foreground" Value="{DynamicResource HnVue.Component.StatusBar.Emergency}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</mah:MetroWindow>
