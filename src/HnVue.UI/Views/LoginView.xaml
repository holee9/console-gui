<UserControl x:Class="HnVue.UI.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1400">
    <Grid Background="{DynamicResource HnVue.Semantic.Surface.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header area -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,32">
            <Viewbox Stretch="Uniform"
                     Height="90"
                     Margin="0,0,0,24">
                <TextBlock Text="HnVUE"
                           Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                           FontSize="54"
                           FontWeight="Bold"/>
            </Viewbox>

            <!-- PPT Slide 3: Section badge "로그인 창" -->
            <Border Background="{DynamicResource HnVue.Component.SectionBadge.Bg}"
                    CornerRadius="3"
                    Padding="8,2"
                    HorizontalAlignment="Center">
                <TextBlock Text="로그인 창"
                           Style="{StaticResource HnVue.SectionBadgeText}"/>
            </Border>
        </StackPanel>

        <!-- Login form panel -->
        <Border Grid.Row="2"
                Width="320"
                HorizontalAlignment="Center"
                Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                CornerRadius="8"
                Padding="28,24">
            <StackPanel>
                <!-- PPT Slide 3: 사용자 label (UppercaseLabel style: 10px/600/#7090b0) -->
                <TextBlock Text="사용자"
                           Style="{StaticResource HnVue.UppercaseLabel}"
                           Margin="0,0,0,4"/>
                <!-- PPT Slide 2/3: UserSelectDropdown (ComboBox) -->
                <ComboBox x:Name="UserComboBox"
                          SelectedValue="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding AvailableUserIds}"
                          IsEditable="True"
                          Height="36"
                          Margin="0,0,0,16"
                          AutomationProperties.Name="사용자 선택"
                          AutomationProperties.HelpText="로그인할 사용자 ID를 입력하거나 선택하세요"/>

                <!-- PPT Slide 3: 비밀번호 label -->
                <TextBlock Text="비밀번호"
                           Style="{StaticResource HnVue.UppercaseLabel}"
                           Margin="0,0,0,4"/>
                <!-- PPT Slide 3: PasswordInput (PasswordBox) -->
                <PasswordBox x:Name="PasswordBox"
                             Height="36"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,24"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             AutomationProperties.Name="비밀번호 입력"
                             AutomationProperties.HelpText="비밀번호를 입력하세요"/>

                <!-- PPT Slide 2/3: 확인/취소 button row -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="취소"
                            Style="{StaticResource HnVue.CancelButton}"
                            Width="90"
                            Height="44"
                            Margin="0,0,8,0"
                            AutomationProperties.Name="취소"
                            AutomationProperties.HelpText="로그인을 취소하고 입력 필드를 초기화합니다"/>
                    <Button Content="확인"
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource HnVue.PrimaryButton}"
                            Width="90"
                            Height="44"
                            AutomationProperties.Name="확인"
                            AutomationProperties.HelpText="입력한 사용자 ID와 비밀번호로 로그인합니다"/>
                </StackPanel>

                <!-- Error message -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#ff8d8d"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
