<UserControl x:Class="HnVue.UI.Views.StudylistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:HnVue.UI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">
    <!--
        @MX:NOTE StudylistView — Studylist screen, PPT 슬라이드 7 (2안/최종안) 재구현.
                 Scope: PPT 슬라이드 5-7 ONLY. Image Viewer/Acquisition 요소 포함 금지 (Issue #59).
                 Layout: header (prev/next + title + PACS) | filter bar | DataGrid | status bar.
                 Date filters: 1 Day, 3 Days, 1 Week, 15 Days, 1 Month (All 제거, Today→1 Day, 15 Days 추가).
                 Columns: PatientId, AccessionNumber, StudyDate, StudyDescription (BodyPart 제거).
                 Colors: hardcoded PPT values matching PatientListView dark theme.
    -->
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Period filter button — active=accent blue bg on press, inactive=dark bg -->
        <Style x:Key="HnVue.PeriodFilterButton" TargetType="Button">
            <Setter Property="Background" Value="#1a2540"/>
            <Setter Property="Foreground" Value="#b0bec5"/>
            <Setter Property="BorderBrush" Value="#2a3a58"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#243050"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#4a6090"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1f6fc7"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nav button (prev/next) — outline style -->
        <Style x:Key="HnVue.NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8899b0"/>
            <Setter Property="BorderBrush" Value="#2a3a58"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontFamily="{TemplateBinding FontFamily}"
                                              TextElement.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1a2a44"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#4a6090"/>
                                <Setter Property="Foreground" Value="#e0e6f0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid column header -->
        <Style x:Key="HnVue.StudyGridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#080e1a"/>
            <Setter Property="Foreground" Value="#7090b0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="{DynamicResource HnVue.Core.FontFamily}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#1e2d4a"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource HnVue.Semantic.Surface.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>   <!-- Header: nav + title + PACS -->
            <RowDefinition Height="40"/>   <!-- Filter bar -->
            <RowDefinition Height="*"/>    <!-- DataGrid -->
            <RowDefinition Height="28"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: Header — prev/next + "Study List" title + PACS dropdown ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                BorderThickness="0,0,0,1"
                Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Prev button — Segoe MDL2 ChevronLeft &#xE76B; -->
                <Button Grid.Column="0"
                        Content="&#xE76B;"
                        Command="{Binding NavigatePreviousCommand}"
                        Style="{StaticResource HnVue.NavButton}"
                        Margin="0,0,4,0"
                        ToolTip="Previous"/>

                <!-- Next button — Segoe MDL2 ChevronRight &#xE76C; -->
                <Button Grid.Column="1"
                        Content="&#xE76C;"
                        Command="{Binding NavigateNextCommand}"
                        Style="{StaticResource HnVue.NavButton}"
                        Margin="0,0,12,0"
                        ToolTip="Next"/>

                <!-- Section title -->
                <TextBlock Grid.Column="2"
                           Text="Study List"
                           Foreground="#e0e6f0"
                           FontSize="14"
                           FontWeight="SemiBold"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                           VerticalAlignment="Center"/>

                <!-- PACS label -->
                <TextBlock Grid.Column="3"
                           Text="PACS:"
                           Foreground="#7090b0"
                           FontSize="12"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>

                <!-- PACS server ComboBox -->
                <ComboBox Grid.Column="4"
                          ItemsSource="{Binding PacsServers}"
                          SelectedItem="{Binding SelectedPacsServer}"
                          Width="120"
                          Height="30"
                          VerticalAlignment="Center"
                          Background="#1a2540"
                          BorderBrush="#2a3a58"
                          BorderThickness="1"
                          Foreground="#e0e6f0"
                          FontSize="12"
                          FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
            </Grid>
        </Border>

        <!-- ═══ Row 1: Period filter buttons + search ═══ -->
        <Grid Grid.Row="1"
              Background="#0a111e">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="190"/>
            </Grid.ColumnDefinitions>

            <!-- Period buttons: 1 Day | 3 Days | 1 Week | 15 Days | 1 Month -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0,8,0">
                <Button Content="1 Day"
                        Command="{Binding FilterByPeriodCommand}"
                        CommandParameter="1Day"
                        Style="{StaticResource HnVue.PeriodFilterButton}"
                        Margin="0,0,4,0"/>
                <Button Content="3 Days"
                        Command="{Binding FilterByPeriodCommand}"
                        CommandParameter="3Days"
                        Style="{StaticResource HnVue.PeriodFilterButton}"
                        Margin="0,0,4,0"/>
                <Button Content="1 Week"
                        Command="{Binding FilterByPeriodCommand}"
                        CommandParameter="1Week"
                        Style="{StaticResource HnVue.PeriodFilterButton}"
                        Margin="0,0,4,0"/>
                <Button Content="15 Days"
                        Command="{Binding FilterByPeriodCommand}"
                        CommandParameter="15Days"
                        Style="{StaticResource HnVue.PeriodFilterButton}"
                        Margin="0,0,4,0"/>
                <Button Content="1 Month"
                        Command="{Binding FilterByPeriodCommand}"
                        CommandParameter="1Month"
                        Style="{StaticResource HnVue.PeriodFilterButton}"/>
            </StackPanel>

            <!-- Search box -->
            <Border Grid.Column="1"
                    Margin="0,6,12,6"
                    Height="28"
                    CornerRadius="3"
                    Background="#1a2540"
                    BorderBrush="#2a3a58"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="&#xE721;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Foreground="#7090b0"
                               VerticalAlignment="Center"
                               Margin="8,0,4,0"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             Foreground="#e0e6f0"
                             BorderThickness="0"
                             FontSize="11"
                             VerticalAlignment="Center"
                             CaretBrush="#7bc8f5"
                             FontFamily="{DynamicResource HnVue.Core.FontFamily}">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Resources>
                                    <VisualBrush x:Key="WatermarkBrush" TileMode="None" Stretch="None" AlignmentX="Left">
                                        <VisualBrush.Visual>
                                            <TextBlock Text="Search studies..."
                                                       Foreground="#4a6080"
                                                       FontSize="11"
                                                       Margin="0"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Style.Resources>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background" Value="{StaticResource WatermarkBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ Row 2: Study DataGrid ═══ -->
        <!-- Columns per PPT 7: PatientId, AccessionNumber, StudyDate, StudyDescription -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Studies}"
                  SelectedItem="{Binding SelectedStudy}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  RowHeight="40"
                  Background="Transparent"
                  BorderThickness="0"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#1e2d4a"
                  ColumnHeaderHeight="32"
                  Foreground="#e0e6f0"
                  FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                  FontSize="12"
                  AlternationCount="2"
                  ColumnHeaderStyle="{StaticResource HnVue.StudyGridHeader}"
                  SelectionMode="Single">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#e0e6f0"/>
                    <Setter Property="Height" Value="40"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="AlternationIndex" Value="1">
                            <Setter Property="Background" Value="#0a111e"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1a3a5c"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Background" Value="#131f35"/>
                        </MultiTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="8,0"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <!-- Patient ID -->
                <DataGridTextColumn Header="Patient ID"
                                    Binding="{Binding PatientId}"
                                    Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <!-- Accession No — PPT 7 명시 컬럼 -->
                <DataGridTextColumn Header="Accession No"
                                    Binding="{Binding AccessionNumber}"
                                    Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <!-- StudyDate — PPT 7: header "StudyDate" -->
                <DataGridTextColumn Header="StudyDate"
                                    Binding="{Binding StudyDate, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                    Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="8,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <!-- StudyDescription — PPT 7: header "StudyDescription" (BodyPart 제거) -->
                <DataGridTextColumn Header="StudyDescription"
                                    Binding="{Binding Description}"
                                    Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ═══ Row 3: Status bar ═══ -->
        <Border Grid.Row="3"
                Background="#080e1a"
                BorderBrush="#1e2d4a"
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Error message -->
                <TextBlock Grid.Column="0"
                           Text="{Binding ErrorMessage}"
                           Foreground="#e74c3c"
                           FontSize="11"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                           VerticalAlignment="Center"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                <!-- Study count -->
                <TextBlock Grid.Column="1"
                           FontSize="11"
                           Foreground="#7090b0"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                           VerticalAlignment="Center">
                    <Run Text="{Binding Studies.Count, Mode=OneWay}"/>
                    <Run Text=" studies"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <Border Grid.Row="2"
                Background="#80050b15"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressBar IsIndeterminate="True"
                         Height="3"
                         VerticalAlignment="Top"
                         Background="Transparent"
                         Foreground="#7bc8f5"/>
        </Border>
    </Grid>
</UserControl>
