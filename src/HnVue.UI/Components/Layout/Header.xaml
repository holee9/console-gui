<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:HnVue.UI.Components.Layout">

    <!-- ═══════════════════════════════════════════════════════════
         Header Component
         Application header with title and action buttons
         ═══════════════════════════════════════════════════════════ -->

    <Style TargetType="local:Header">
        <Setter Property="Background" Value="{StaticResource DS2026.Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource DS2026.Brush.Border}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="16,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:Header">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Height="{TemplateBinding Height}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Left: Navigation / Menu -->
                            <ContentControl Grid.Column="0"
                                           Content="{TemplateBinding LeftContent}"
                                           VerticalAlignment="Center" />

                            <!-- Center: Title -->
                            <TextBlock Grid.Column="1"
                                       Text="{TemplateBinding Title}"
                                       Style="{StaticResource DS2026.Typography.H3}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />

                            <!-- Right: Actions -->
                            <ItemsControl Grid.Column="2"
                                          ItemsSource="{TemplateBinding ActionButtons}"
                                          VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style>
                                        <Setter Property="FrameworkElement.Margin" Value="8,0,0,0" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Header Typography Styles -->
    <Style x:Key="DS2026.Typography.Display" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DS2026.FontFamily.Primary}" />
        <Setter Property="FontSize" Value="{StaticResource DS2026.FontSize.Display}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource DS2026.Brush.Text}" />
        <Setter Property="LineHeight" Value="{StaticResource DS2026.LineHeight.Display}" />
    </Style>

    <Style x:Key="DS2026.Typography.H1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DS2026.FontFamily.Primary}" />
        <Setter Property="FontSize" Value="{StaticResource DS2026.FontSize.H1}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource DS2026.Brush.Text}" />
        <Setter Property="LineHeight" Value="{StaticResource DS2026.LineHeight.H1}" />
    </Style>

    <Style x:Key="DS2026.Typography.H2" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DS2026.FontFamily.Primary}" />
        <Setter Property="FontSize" Value="{StaticResource DS2026.FontSize.H2}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource DS2026.Brush.Text}" />
        <Setter Property="LineHeight" Value="{StaticResource DS2026.LineHeight.H2}" />
    </Style>

    <Style x:Key="DS2026.Typography.H3" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DS2026.FontFamily.Primary}" />
        <Setter Property="FontSize" Value="{StaticResource DS2026.FontSize.H3}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource DS2026.Brush.Text}" />
        <Setter Property="LineHeight" Value="{StaticResource DS2026.LineHeight.H3}" />
    </Style>

    <Style x:Key="DS2026.Typography.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DS2026.FontFamily.Primary}" />
        <Setter Property="FontSize" Value="{StaticResource DS2026.FontSize.Body}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource DS2026.Brush.Text}" />
        <Setter Property="LineHeight" Value="{StaticResource DS2026.LineHeight.Body}" />
    </Style>

    <Style x:Key="DS2026.Typography.Caption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DS2026.FontFamily.Primary}" />
        <Setter Property="FontSize" Value="{StaticResource DS2026.FontSize.Caption}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource DS2026.Brush.TextMuted}" />
        <Setter Property="LineHeight" Value="{StaticResource DS2026.LineHeight.Caption}" />
    </Style>

</ResourceDictionary>
