<UserControl x:Class="HnVue.UI.Views.MergeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:HnVue.UI.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
    <!--
        @MX:NOTE MergeView — "Sync Study" dialog. PPT 슬라이드 13.
                 Renamed from "Same Studylist". Three-column layout:
                 Left = Patient A search/list, Center = Preview + thumbnail strip,
                 Right = Patient B search/list. Bottom bar: Cancel / Sync Study.
                 PatientRecord.Name is DICOM PN format (family^given^...).
    -->
    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource HnVue.Semantic.Surface.Page}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                BorderThickness="0,0,0,1"
                Padding="16,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE8FD;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="16"
                           Foreground="{DynamicResource HnVue.Semantic.Brand.Accent}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBlock Text="Sync Study"
                           Style="{StaticResource HnVue.SectionHeader}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Three-column main area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════ Patient A Panel ═══════════════════ -->
            <Border Grid.Column="0"
                    Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                    BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                    BorderThickness="0,0,1,0"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Patient A"
                               Style="{StaticResource HnVue.SectionHeader}"
                               Margin="0,0,0,8"/>

                    <!-- Search A row -->
                    <Border Grid.Row="1"
                            Height="32" CornerRadius="4"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1"
                            Margin="0,0,0,8"
                            Padding="8,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchQueryA, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                                     BorderThickness="0" FontSize="12"
                                     VerticalAlignment="Center"
                                     FontFamily="{DynamicResource HnVue.Core.FontFamily}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SearchACommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="2"
                                    Content="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding SearchACommand}"
                                    Style="{StaticResource HnVue.OutlineButton}"
                                    Width="28" Height="26" Padding="0" FontSize="12"/>
                        </Grid>
                    </Border>

                    <!-- Patient A list -->
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding PatientsA}"
                             SelectedItem="{Binding SelectedPatientA}"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="{DynamicResource HnVue.Core.FontFamily}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Height" Value="40"/>
                                <Setter Property="Padding" Value="8,0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Border.Default}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Brand.Primary}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Surface.Card}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center">
                                    <!-- PatientRecord.Name is DICOM PN format (family^given) -->
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold" FontSize="12"
                                               FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                                    <TextBlock Text="{Binding PatientId}"
                                               FontSize="11"
                                               Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                               FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ═══════════════════ Center Preview Panel ═══════════════════ -->
            <Border Grid.Column="1"
                    Background="{DynamicResource HnVue.Semantic.Surface.Page}"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="80"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Preview"
                               Style="{StaticResource HnVue.SectionHeader}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <!-- Two preview image placeholders side by side -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Image A placeholder -->
                        <Border Grid.Column="0"
                                Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                                BorderThickness="1"
                                Margin="0,0,4,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8B9;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="28"
                                           Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="A"
                                           FontSize="12"
                                           Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                           HorizontalAlignment="Center"
                                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Image B placeholder -->
                        <Border Grid.Column="1"
                                Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                                BorderThickness="1"
                                Margin="4,0,0,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8B9;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="28"
                                           Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="B"
                                           FontSize="12"
                                           Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                           HorizontalAlignment="Center"
                                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Thumbnail strip (PPT: 중앙 섹션에 Thumbnail 추가) -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="0,1,0,0"
                            Padding="4">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding PreviewStudiesA}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="64" Height="64"
                                                Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                                                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                                                BorderThickness="1"
                                                Margin="0,0,4,0"
                                                ToolTip="{Binding Description}">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="&#xE8B9;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="20"
                                                           Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding BodyPart}"
                                                           FontSize="9"
                                                           Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                                           HorizontalAlignment="Center"
                                                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════════════════ Patient B Panel ═══════════════════ -->
            <Border Grid.Column="2"
                    Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                    BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                    BorderThickness="1,0,0,0"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Patient B"
                               Style="{StaticResource HnVue.SectionHeader}"
                               Margin="0,0,0,8"/>

                    <!-- Search B row -->
                    <Border Grid.Row="1"
                            Height="32" CornerRadius="4"
                            Background="{DynamicResource HnVue.Semantic.Surface.Card}"
                            BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                            BorderThickness="1"
                            Margin="0,0,0,8"
                            Padding="8,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchQueryB, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     Foreground="{DynamicResource HnVue.Semantic.Text.Primary}"
                                     BorderThickness="0" FontSize="12"
                                     VerticalAlignment="Center"
                                     FontFamily="{DynamicResource HnVue.Core.FontFamily}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SearchBCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="2"
                                    Content="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                    Command="{Binding SearchBCommand}"
                                    Style="{StaticResource HnVue.OutlineButton}"
                                    Width="28" Height="26" Padding="0" FontSize="12"/>
                        </Grid>
                    </Border>

                    <!-- Patient B list -->
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding PatientsB}"
                             SelectedItem="{Binding SelectedPatientB}"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="{DynamicResource HnVue.Core.FontFamily}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Height" Value="40"/>
                                <Setter Property="Padding" Value="8,0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource HnVue.Semantic.Text.Primary}"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource HnVue.Semantic.Border.Default}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Brand.Primary}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource HnVue.Semantic.Surface.Card}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold" FontSize="12"
                                               FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                                    <TextBlock Text="{Binding PatientId}"
                                               FontSize="11"
                                               Foreground="{DynamicResource HnVue.Semantic.Text.Secondary}"
                                               FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom action bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource HnVue.Semantic.Surface.Panel}"
                BorderBrush="{DynamicResource HnVue.Semantic.Border.Default}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Error message -->
                <TextBlock Grid.Column="0"
                           Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource HnVue.Semantic.Status.Emergency}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontFamily="{DynamicResource HnVue.Core.FontFamily}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>

                <Button Grid.Column="1"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource HnVue.OutlineButton}"
                        Width="100" Height="36"
                        Margin="0,0,8,0"
                        FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>

                <Button Grid.Column="2"
                        Content="Sync Study"
                        Command="{Binding MergeCommand}"
                        Style="{StaticResource HnVue.PrimaryButton}"
                        Width="120" Height="36"
                        FontFamily="{DynamicResource HnVue.Core.FontFamily}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
